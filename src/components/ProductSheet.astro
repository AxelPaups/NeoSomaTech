---
// src/components/ProductSheet.astro
const { nom, prix, desc_simple, desc_longue, image, lien } = Astro.props;
---

<article class="product-container">
  <div class="grid">
    <div class="image-box">
      <img src={image} alt={nom} />
    </div>

    <div class="content">
      <h1 class="title">{nom}</h1>
      <p class="tagline">{desc_simple}</p>
      
      <div class="price-tag">{prix} €</div>
      
      <div class="divider"></div>
      
      <div class="main-description">
        <h3>À propos de cet équipement</h3>
        <p>{desc_longue}</p>
      </div>

      <a href={lien} class="buy-button">
        Vérifier la disponibilité
      </a>
    </div>
  </div>
</article>

<style>
  .product-container {
    background: #0f172a;
    color: white;
    padding: 3rem;
    border-radius: 20px;
    border: 1px solid #1e293b;
    max-width: 1000px;
    margin: 2rem auto;
    font-family: sans-serif;
  }
  .grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: center; }
  .image-box img { width: 100%; border-radius: 12px; }
  .title { font-size: 2.5rem; margin: 0; color: #fff; }
  .tagline { color: #8B5CF6; font-weight: bold; text-transform: uppercase; margin-bottom: 1rem; }
  .price-tag { font-size: 2rem; color: #06B6D4; font-weight: bold; }
  .divider { height: 1px; background: #1e293b; margin: 2rem 0; }
  .buy-button {
    display: inline-block;
    background: #8B5CF6;
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    margin-top: 2rem;
  }
  @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
</style>