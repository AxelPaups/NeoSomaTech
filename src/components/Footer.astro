---
/**
 * Footer Component - NeoSomaTech
 * Design: Dark Tech / Ultra Premium
 * Dynamique : Données récupérées depuis Directus
 */
import { fetchDirectus } from "../lib/directus";

const currentYear = new Date().getFullYear();

let produits: any[] = [];
let articles: any[] = [];

try {
  [produits, articles] = await Promise.all([
    fetchDirectus("/items/Produits?fields=Nom_du_produit,slug&limit=10"),
    fetchDirectus("/items/Articles?sort=-date_publication&limit=3&fields=titre,slug")
  ]);
} catch (error) {
  console.error("Erreur lors de la récupération des données du footer:", error);
}

// Fonction utilitaire pour nettoyer les titres (avant les deux points)
const cleanTitle = (title: string) => {
  if (!title) return "";
  return title.includes(':') ? title.split(':')[0].trim() : title;
};
---

<footer class="footer">
  <div class="container footer-grid">
    <!-- Colonne 1: Logo & Social -->
    <div class="footer-col brand-col">
      <a href="/" class="footer-logo">
        <span class="logo-text">NEOSOMA</span><span class="logo-tech">TECH</span>
      </a>
      <p class="brand-slogan">
        Augmenter le potentiel humain grâce aux technologies d'exosquelettes de pointe.
      </p>
      <div class="social-links">
        <span class="social-icon" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </span>
        <span class="social-icon" aria-label="X (Twitter)">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
        </span>
        <span class="social-icon" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </span>
      </div>
    </div>

    <!-- Colonne 2: Nos Produits (Dynamique) -->
    <div class="footer-col">
      <h3>Nos Produits</h3>
      <nav>
        <ul>
          {produits.map((prd) => (
            <li>
              <a href={`/produits/${prd.slug}`}>{prd.Nom_du_produit}</a>
            </li>
          ))}
          {produits.length === 0 && (
            <>
              <li><a href="/produits/ski-mojo">Ski-Mojo</a></li>
              <li><a href="/produits/hypershell">Hypershell</a></li>
            </>
          )}
        </ul>
      </nav>
    </div>

    <!-- Colonne 3: Articles (Derniers 3 dynamique) -->
    <div class="footer-col">
      <h3>Articles</h3>
      <nav>
        <ul>
          {articles.map((art) => (
            <li>
              <a href={`/articles/${art.slug}`}>{cleanTitle(art.titre)}</a>
            </li>
          ))}
          {articles.length === 0 && (
            <li><a href="/articles">Dernières actualités</a></li>
          )}
        </ul>
      </nav>
    </div>

    <!-- Colonne 4: Légal & France -->
    <div class="footer-col">
      <h3>Légal & France</h3>
      <nav>
        <ul>
          <li><a href="/mentions-legales">Mentions légales</a></li>
          <li><a href="/politique-cookies">Politique de cookies</a></li>
          <li><a href="/a-propos">À propos</a></li>
        </ul>
      </nav>
      <div class="france-mention">
        <p>Ingénierie & Passion</p>
        <p>Basé en France 🇫🇷</p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container bottom-inner">
      <p class="copyright">&copy; {currentYear} NeoSomaTech. Tous droits réservés.</p>
      <a href="#top" class="back-to-top">
        <span>Back to top</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #050505;
    color: #a1a1aa;
    padding: 5rem 0 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-family: inherit;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .footer-col h3 {
    color: #ffffff;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .brand-col {
    grid-column: span 1;
  }

  .footer-logo {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: 900;
    text-decoration: none;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
  }

  .logo-text {
    color: #ffffff;
  }

  .logo-tech {
    color: #0047AB; /* Bleu Cobalt */
  }

  .brand-slogan {
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #a1a1aa;
    transition: all 0.3s ease;
    cursor: default; /* Car pas de lien comme demandé */
  }

  .social-icon:hover {
    color: #0047AB;
    border-color: #0047AB;
    background: rgba(0, 71, 171, 0.1);
    transform: translateY(-2px);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  nav ul li {
    margin-bottom: 0.75rem;
  }

  nav ul li a {
    color: #a1a1aa;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  nav ul li a:hover {
    color: #0047AB;
  }

  .france-mention {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .france-mention p {
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    font-size: 0.85rem;
  }

  .back-to-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .back-to-top:hover {
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .footer {
      padding-top: 3.5rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .bottom-inner {
      flex-direction: column;
      text-align: center;
    }
    
    .back-to-top {
      order: -1;
    }
  }
</style>
