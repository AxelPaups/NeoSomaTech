---
interface Props {
	icon: 'weight' | 'battery' | 'assist' | 'charge' | 'material' | 'warranty' | 'cert';
}
const { icon } = Astro.props;
---

<svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
	{icon === 'weight' && (
		<>
			<path d="M12 3v18" />
			<path d="M6 8h12" />
			<path d="M8 21h8" />
		</>
	)}
	{icon === 'battery' && (
		<>
			<rect x="2" y="7" width="18" height="10" rx="2" />
			<path d="M22 11v2" />
			<path d="M6 11h4" />
			<path d="M14 11h2" />
		</>
	)}
	{icon === 'assist' && (
		<>
			<path d="M12 2v4" />
			<path d="m4.93 4.93 2.83 2.83" />
			<path d="M2 12h4" />
			<path d="m4.93 19.07 2.83-2.83" />
			<path d="M12 18v4" />
			<path d="m19.07 19.07-2.83-2.83" />
			<path d="M18 12h4" />
			<path d="m19.07 4.93-2.83 2.83" />
		</>
	)}
	{icon === 'charge' && (
		<>
			<path d="M13 2 3 14h9l-1 8 10-12h-9z" />
		</>
	)}
	{icon === 'material' && (
		<>
			<path d="M12 22 2 12l10-10 10 10z" />
		</>
	)}
	{icon === 'warranty' && (
		<>
			<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
			<path d="m9 12 2 2 4-4" />
		</>
	)}
	{icon === 'cert' && (
		<>
			<circle cx="12" cy="8" r="6" />
			<path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11" />
		</>
	)}
</svg>

<style>
	.spec-icon {
		width: 1.35rem;
		height: 1.35rem;
		flex-shrink: 0;
	}
</style>
