---
// page : /boutique/[marque]  — page de marque indexable (SEO)
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus, directusUrl, slugifyBrand } from '../../lib/directus';

const { marque: marqueSlug } = Astro.params;

let produits: any[] = [];
let brandName = '';
let errorMessage: string | null = null;

try {
    const all = await fetchDirectus(
        '/items/Produits?fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque,promo,prix_promo&limit=200'
    );
    const matched = (all || []).filter(
        (p: any) => p.marque && slugifyBrand(p.marque) === marqueSlug
    );
    if (matched.length > 0) {
        brandName = matched[0].marque;
        produits = matched;
    }
} catch (error: any) {
    console.error(`Erreur page marque ${marqueSlug}:`, error);
    errorMessage = error.message;
}

// Marque inconnue (et pas d'erreur Directus) : on renvoie vers la boutique générale.
if (!brandName && !errorMessage) {
    return Astro.redirect('/boutique', 302);
}

// Introductions éditoriales par marque (clé = slug), avec repli générique.
const BRAND_INTROS: Record<string, string> = {
    'ski-mojo':
        "Ski-Mojo est l'exosquelette de ski passif de référence : un système de ressorts qui reprend jusqu'à 33 % de la charge sur les genoux pour skier plus longtemps, sans fatigue ni douleur. Découvrez ci-dessous notre sélection Ski-Mojo.",
    hypershell:
        "Hypershell conçoit des exosquelettes de marche motorisés à assistance intelligente : des moteurs pilotés par IA qui allègent vos pas en randonnée et au quotidien. Retrouvez ci-dessous la gamme Hypershell sélectionnée par NeoSomaTech.",
    stoko:
        "Stoko réinvente le maintien articulaire avec ses collants exosquelettes : un soutien médical du genou intégré à un vêtement de compression léger et invisible. Voici notre sélection Stoko.",
    dnsys:
        "Dnsys développe des exosquelettes d'assistance pour la marche et l'effort. Découvrez ci-dessous les modèles Dnsys référencés par NeoSomaTech.",
};
const intro =
    BRAND_INTROS[marqueSlug ?? ''] ||
    `Découvrez la sélection d'exosquelettes ${brandName} référencée par NeoSomaTech : caractéristiques, prix et conseils d'achat.`;

const title = `Exosquelettes ${brandName} : modèles, prix et avis | NeoSomaTech`;
const description = `Gamme d'exosquelettes ${brandName} sélectionnée par NeoSomaTech : modèles, caractéristiques, prix et guide d'achat. Livraison France.`;

const itemListSchema = {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Exosquelettes ${brandName} — NeoSomaTech`,
    url: `https://neosomatech.com/boutique/${marqueSlug}`,
    numberOfItems: produits.length,
    itemListElement: produits.map((p: any, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://neosomatech.com/produits/${p.slug || p.id}`,
        name: p.Nom_du_produit,
    })),
};
---

<Layout title={title} description={description}>
    {produits.length > 0 && (
        <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
    )}

    <header class="page-header container">
        <div class="breadcrumb">
            <a href="/">Accueil</a> / <a href="/boutique">Boutique</a> / <span>{brandName}</span>
        </div>
        <h1>Exosquelettes <span class="gradient-text">{brandName}</span></h1>
        <p class="brand-intro">{intro}</p>
    </header>

    <div class="container" style="padding-bottom: 5rem;">
        {errorMessage ? (
            <div class="error-box"><strong>⚠️</strong> {errorMessage}</div>
        ) : produits.length === 0 ? (
            <div class="empty-box"><p>Aucun produit {brandName} disponible pour le moment.</p></div>
        ) : (
            <div class="grid">
                {produits.map((p) => {
                    const isPromoValid = p.promo && p.prix_promo;
                    const displayPromoPrice = isPromoValid
                        ? (String(p.prix_promo).includes('€') ? p.prix_promo : `${p.prix_promo} €`)
                        : null;
                    return (
                        <article class="card">
                            <a href={`/produits/${p.slug || p.id}`} class="card-img-link">
                                {p.image ? (
                                    <img
                                        src={`${directusUrl}/assets/${p.image}?width=400&format=webp&quality=82`}
                                        alt={p.Nom_du_produit}
                                        loading="lazy"
                                        decoding="async"
                                        width="400"
                                        height="400"
                                    />
                                ) : (
                                    <div class="img-placeholder">🦾</div>
                                )}
                                {isPromoValid && <div class="promo-badge">Promo</div>}
                            </a>
                            <div class="card-body">
                                <div class="card-tag">{brandName}</div>
                                <h2 class="card-title">
                                    <a href={`/produits/${p.slug || p.id}`}>{p.Nom_du_produit}</a>
                                </h2>
                                <p class="card-desc">{p.descripton_simple}</p>
                                <div class="card-footer">
                                    {isPromoValid ? (
                                        <div class="price-wrapper">
                                            <span class="price old-price">{p.prix} €</span>
                                            <span class="price promo-price">{displayPromoPrice}</span>
                                        </div>
                                    ) : (
                                        <span class="price">{p.prix ? `${p.prix} €` : 'Nous contacter'}</span>
                                    )}
                                    <a href={`/produits/${p.slug || p.id}`} class="btn">Voir &rarr;</a>
                                </div>
                            </div>
                        </article>
                    );
                })}
            </div>
        )}

        <div class="all-products-link">
            <a href="/boutique" class="btn btn-outline">&larr; Tous les exosquelettes</a>
        </div>
    </div>
</Layout>

<style>
    .page-header { padding: 4rem 1.5rem 2rem; text-align: center; }
    .breadcrumb { font-size: 0.83rem; color: var(--text-light); margin-bottom: 1rem; }
    .breadcrumb a { color: #818cf8; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: #fff; letter-spacing: -1.5px; margin-bottom: 1rem; }
    .gradient-text {
        background: linear-gradient(135deg, #6366f1, #8b5cf6, #ec4899);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .brand-intro { color: var(--text-light); max-width: 720px; margin: 0 auto; line-height: 1.7; }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
        gap: 1.75rem;
    }
    .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, border-color 0.2s;
    }
    .card:hover { transform: translateY(-4px); border-color: var(--primary); }
    .card-img-link { display: flex; align-items: center; justify-content: center; aspect-ratio: 1 / 1; background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(139,92,246,0.15)); padding: 2rem; overflow: hidden; }
    .card-img-link img { width: 100%; height: 100%; object-fit: contain; background: #F5F2EB; border-radius: 6px; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .card:hover .card-img-link img { transform: scale(1.3); }
    .img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; background: #F5F2EB; border-radius: 6px; }
    .promo-badge {
        position: absolute; top: 0.75rem; left: 0.75rem;
        background: linear-gradient(135deg, #ec4899, #8b5cf6);
        color: #fff; font-size: 0.7rem; font-weight: 700;
        padding: 0.25rem 0.6rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .card-body { padding: 1.25rem; display: flex; flex-direction: column; flex: 1; gap: 0.6rem; }
    .card-tag { font-size: 0.72rem; color: #a5b4fc; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
    .card-title { font-size: 1.05rem; font-weight: 700; line-height: 1.3; }
    .card-title a { color: #fff; text-decoration: none; }
    .card-title a:hover { color: #a5b4fc; }
    .card-desc { color: var(--text-light); font-size: 0.9rem; line-height: 1.5; flex: 1; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-top: 0.5rem; }
    .price { font-weight: 800; color: #fff; font-size: 1.1rem; }
    .price-wrapper { display: flex; flex-direction: column; }
    .old-price { font-size: 0.85rem; color: var(--text-light); text-decoration: line-through; font-weight: 500; }
    .promo-price { color: #f0abfc; }
    .card-footer .btn { padding: 0.5rem 0.9rem; font-size: 0.9rem; }

    .error-box, .empty-box {
        text-align: center; padding: 2rem; border-radius: 12px;
        background: rgba(255,255,255,0.03); border: 1px solid var(--border); color: var(--text-light);
    }
    .all-products-link { text-align: center; margin-top: 3rem; }
</style>
