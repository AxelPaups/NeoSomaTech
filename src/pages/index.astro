---
import Layout from "../layouts/Layout.astro";
import { fetchDirectus } from "../lib/directus";

let produits: any[] = [];
let articles: any[] = [];
let errorMessage: string | null = null;

try {
	[produits, articles] = await Promise.all([
		fetchDirectus(
			"/items/Produits?limit=3&fields=id,Nom_du_produit,prix,descripton_simple,slug,image",
		),
		fetchDirectus(
			"/items/Articles?limit=3&sort=-date_publication&fields=id,titre,slug,description_seo,date_publication,auteur,image_principale",
		),
	]);

	// Tri manuel pour garantir le classement antéchronologique (le plus récent en haut)
	if (Array.isArray(articles)) {
		articles.sort((a, b) => {
			const dateA = a.date_publication ? new Date(a.date_publication).getTime() : 0;
			const dateB = b.date_publication ? new Date(b.date_publication).getTime() : 0;
			return dateB - dateA; // Décroissant
		});
	}
} catch (error: any) {
	console.error("Erreur Directus:", error);
	errorMessage = error.message;
}

const directusUrl = "https://spirited-squid.pikapod.net";
const formatDate = (date: string) => {
	if (!date) return "";
	try {
		const d = new Date(date);
		if (isNaN(d.getTime())) return date;
		return new Intl.DateTimeFormat("fr-FR", {
			year: "numeric",
			month: "long",
			day: "numeric",
		}).format(d);
	} catch (e) {
		return date;
	}
};
---

<Layout
	title="NeoSomaTech - Expert Exosquelettes Médicaux, Sportifs et Industriels"
	description="NeoSomaTech, référence francophone des exosquelettes sportifs et médicaux. Découvrez nos sélections, comparatifs et guides d'achat : Ski-Mojo, Hypershell, Stoko. Livraison France."
>
	<!-- Données Structurées JSON-LD -->
	<!-- Données Structurées JSON-LD -->
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "NeoSomaTech",
			"url": "https://neosomatech.com",
			"description": "Boutique et expert en solutions d'exosquelettes pour la santé et le sport.",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://neosomatech.com/boutique?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
	</script>
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "NeoSomaTech",
			"url": "https://neosomatech.com",
			"logo": "https://neosomatech.com/favicon.png",
			"description": "NeoSomaTech est le spécialiste français des exosquelettes médicaux, industriels et sportifs, offrant expertise et solutions innovantes pour la mobilité humaine.",
			"sameAs": []
		}
	</script>
	<!-- ===== HERO ===== -->
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="container hero-content">
			<div class="hero-badge">✦ Spécialiste Exosquelettes</div>
			<h1>
				L'avenir du corps<br /><span class="gradient-text"
					>commence ici</span
				>
			</h1>
			<p class="hero-sub">
				Découvrez une sélection d'exosquelettes de pointe et lisez nos
				analyses approfondies pour faire le meilleur choix.
			</p>
			<div class="hero-actions">
				<a href="/boutique" class="btn">Voir les produits &rarr;</a>
				<a href="/articles" class="btn btn-outline">Lire nos articles</a
				>
			</div>
		</div>
	</section>

	<!-- ===== MISSION ===== -->
	<section class="mission-section">
		<div class="container mission-inner">
			<div class="mission-text">
				<span class="section-label">Notre mission</span>
				<h2>L'exosquelette accessible à tous</h2>
				<p>
					NeoSomaTech est la référence francophone dédiée aux <strong
						>exosquelettes médicaux, industriels et sportifs</strong
					>. Notre équipe d'experts analyse, compare et sélectionne
					les meilleures solutions pour augmenter les capacités
					humaines — que vous soyez professionnel de santé, industriel
					ou sportif en quête de mobilité retrouvée.
				</p>
				<p>
					Chaque produit référencé sur notre boutique est
					soigneusement évalué selon des critères de <strong
						>performance, sécurité et ergonomie</strong
					>. Nos guides et comparatifs approfondis vous permettent de
					choisir en toute confiance.
				</p>
			</div>
			<div class="mission-pillars">
				<div class="pillar-card">
					<div class="pillar-icon-wrapper">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-microscope"><path d="M6 18h8"/><path d="M3 22h18"/><path d="m14 22-4-4 4-4"/><path d="m9 14 2 2"/><path d="M12 21a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z"/><path d="M18 12.2V7a5 5 0 0 0-5-5"/><path d="M11 5a4 4 0 0 1 4 4v2"/></svg>
					</div>
					<div class="pillar-content">
						<h3>Expertise technique</h3>
						<p>Des analyses détaillées rédigées par des spécialistes en robotique et biomécanique.</p>
					</div>
				</div>
				<div class="pillar-card">
					<div class="pillar-icon-wrapper">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><path d="m13 2-2 10h3L11 22l2-10h-3z"/></svg>
					</div>
					<div class="pillar-content">
						<h3>Innovation continue</h3>
						<p>Veille technologique permanente sur les dernières avancées du marché mondial.</p>
					</div>
				</div>
				<div class="pillar-card">
					<div class="pillar-icon-wrapper">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-handshake"><path d="m11 17 2 2 6-6"/><path d="m18 14 2.5 2.5a3.3 3.3 0 0 1 0 4.7 3.3 3.3 0 0 1-4.7 0L13.5 19"/><path d="M18 14 14.4 7.1a3.3 3.3 0 0 0-4.7 0L4.2 12.6a3.3 3.3 0 0 0 0 4.7l4.2 4.2a3.3 3.3 0 0 0 4.7 0l1.9-1.9"/><path d="M8 11v.01"/><path d="M16 15v.01"/></svg>
					</div>
					<div class="pillar-content">
						<h3>Accompagnement</h3>
						<p>Conseils personnalisés pour identifier l'exosquelette le plus adapté à vos besoins.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== PRODUITS ===== -->
	<section class="section container">
		<div class="section-header">
			<span class="section-label">Sélection Exclusive</span>
			<h2>Nos Exosquelettes</h2>
			<p>L'alliance parfaite de la technologie et du mouvement.</p>
		</div>

		{
			errorMessage ? (
				<div class="error-box">
					<strong>⚠️</strong> {errorMessage}
				</div>
			) : produits.length === 0 ? (
				<div class="empty-box">
					<p>Aucun produit pour le moment.</p>
				</div>
			) : (
				<div class="products-grid">
					{produits.map((produit) => (
						<article class="product-card">
							<div class="product-img-wrapper">
								{produit.image ? (
									<img
										src={`${directusUrl}/assets/${produit.image}`}
										alt={produit.Nom_du_produit}
										loading="lazy"
									/>
								) : (
									<div class="img-placeholder">🦾</div>
								)}
								<div class="product-badge">Top Product</div>
							</div>
							<div class="product-info">
								<div class="product-tag">Exosquelette</div>
								<h3>{produit.Nom_du_produit}</h3>
								<p class="product-desc">
									{produit.descripton_simple}
								</p>
								<div class="product-footer">
									<div class="price-container">
										<span class="price-label">À partir de</span>
										<span class="price">
											{produit.prix
												? `${produit.prix} €`
												: "Sur devis"}
										</span>
									</div>
									<a
										href={`/produits/${produit.slug || produit.id}`}
										class="btn-icon"
										aria-label={`Voir ${produit.Nom_du_produit}`}
									>
										&rarr;
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
			)
		}
		<div class="section-footer">
			<a href="/boutique" class="btn btn-outline">Découvrir toute la boutique &rarr;</a>
		</div>
	</section>

	<!-- ===== ARTICLES ===== -->
	{
		articles.length > 0 && (
			<section class="section articles-section">
				<div class="container">
					<div class="section-header">
						<h2>Derniers Articles</h2>
						<p>
							Guides, comparatifs et actualités sur les
							exosquelettes.
						</p>
						<a href="/articles" class="see-all">
							Voir tous les articles &rarr;
						</a>
					</div>
					<div class="articles-grid">
						{articles.map((article) => (
							<article class="article-card">
								{article.image_principale && (
									<a
										href={`/articles/${article.slug}`}
										class="article-img"
									>
										<img
											src={`${directusUrl}/assets/${article.image_principale}`}
											alt={article.titre}
											loading="lazy"
										/>
									</a>
								)}
								<div class="article-body">
									<div class="article-meta">
										{article.date_publication && (
											<time>
												{formatDate(
													article.date_publication,
												)}
											</time>
										)}
										{article.auteur && (
											<span>· {article.auteur}</span>
										)}
									</div>
									<h3>
										<a href={`/articles/${article.slug}`}>
											{article.titre}
										</a>
									</h3>
									{article.description_seo && (
										<p class="article-excerpt">
											{article.description_seo}
										</p>
									)}
									<a
										href={`/articles/${article.slug}`}
										class="read-link"
									>
										Lire la suite &rarr;
									</a>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- ===== CTA FINAL ===== -->
	<section class="cta-section container">
		<div class="cta-box">
			<h2>Une question sur les exosquelettes ?</h2>
			<p>
				Notre équipe est disponible pour vous conseiller dans votre
				choix.
			</p>
			<a href="/contact" class="btn">Nous contacter &rarr;</a>
		</div>
	</section>
</Layout>

<style>
