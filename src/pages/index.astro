---
import Layout from '../layouts/Layout.astro';
import directus from '../lib/directus';
import { readItems } from '@directus/sdk';

// Récupération des produits depuis Directus
let produits = [];
try {
  produits = await directus.request(readItems('Produits'));
} catch (error) {
  console.error("Erreur lors de la récupération des produits:", error);
}

const title = "Expert Exosquelettes | La Performance Augmentée";
---

<Layout title={title}>
	<main>
		<section class="hero">
			<div class="hero-content">
				<h1>L'Avenir du <span class="text-gradient">Mouvement</span></h1>
				<p>Solutions d'assistance physique haute performance pour l'industrie et la rééducation.</p>
				<div class="actions">
					<a href="#produits" class="btn-primary">Découvrir la gamme</a>
				</div>
			</div>
		</section>

		<section id="produits" class="products-section">
			<h2>Nos Systèmes <span class="text-gradient">Disponibles</span></h2>
			
			<div class="product-grid">
				{produits.length > 0 ? (
					produits.map((produit) => (
						<div class="product-card">
							<div class="badge">Innovation 2026</div>
							<div class="product-info">
								<h3>{produit.nom}</h3>
								<p class="description">{produit.description || "Système d'assistance motorisé haute précision."}</p>
								<div class="product-footer">
									<span class="price">{produit.prix} €</span>
									<button class="btn-small">Détails</button>
								</div>
							</div>
						</div>
					))
				) : (
					<p class="empty">Aucun produit trouvé. Vérifiez votre connexion Directus.</p>
				)}
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		color: white;
		line-height: 1.6;
	}
	.hero {
		padding: 8rem 2rem;
		text-align: center;
		background: radial-gradient(circle at center, #1a1a2e 0%, #0f172a 100%);
	}
	h1 {
		font-size: 4rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}
	.text-gradient {
		background-image: linear-gradient(45deg, #4f46e5, #06b6d4);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	p.description {
		font-size: 0.9rem;
		color: #94a3b8;
		margin-bottom: 1.5rem;
	}
	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		padding: 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.product-card {
		background: #1e293b;
		border: 1px solid #334155;
		border-radius: 12px;
		padding: 1.5rem;
		position: relative;
		transition: transform 0.2s;
	}
	.product-card:hover {
		transform: translateY(-5px);
		border-color: #4f46e5;
	}
	.badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: #4f46e5;
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 20px;
	}
	.price {
		font-size: 1.25rem;
		font-weight: bold;
		color: #22d3ee;
	}
	.product-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: auto;
	}
	.btn-primary {
		background: #4f46e5;
		color: white;
		padding: 0.8rem 1.5rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: bold;
	}
	.btn-small {
		background: transparent;
		border: 1px solid #4f46e5;
		color: white;
		padding: 0.4rem 0.8rem;
		border-radius: 6px;
		cursor: pointer;
	}
	h2 {
		text-align: center;
		font-size: 2.5rem;
		margin-top: 4rem;
	}
</style>