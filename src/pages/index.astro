		inset: 0;
		background: radial-gradient(
			ellipse 100% 70% at 50% 0%,
			rgba(99, 102, 241, 0.22) 0%,
			transparent 70%
		);
		pointer-events: none;
	}
	.hero-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
