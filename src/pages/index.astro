		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(99, 102, 241, 0.2);
	}
	.product-img-wrapper {
		position: relative;
		aspect-ratio: 1/1;
		overflow: hidden;
		background: #000;
	}
	.product-img-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.product-card:hover .product-img-wrapper img {
		transform: scale(1.1);
	}
	.img-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 4rem;
		background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
		color: rgba(99, 102, 241, 0.3);
	}
	.product-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: var(--gradient);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.4rem 0.8rem;
		border-radius: 99px;
		box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.product-info {
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		flex: 1;
	}
	.product-tag {
		font-size: 0.7rem;
		font-weight: 700;
		color: #818cf8;
		text-transform: uppercase;
		letter-spacing: 1.5px;
