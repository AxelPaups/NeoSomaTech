---
import Layout from '../layouts/Layout.astro';
import { fetchDirectus } from '../lib/directus';

let produits: any[] = [];
let errorMessage: string | null = null;

try {
    produits = await fetchDirectus('/items/Produits?limit=10&fields=id,Nom_du_produit,prix,descripton_simple');
} catch (error: any) {
    console.error("Erreur Directus:", error);
    errorMessage = error.message;
}
---

<Layout title="NeoSomaTech - Accueil" description="Découvrez notre sélection de produits exclusifs.">

	<!-- HERO -->
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="container hero-content">
			<div class="hero-badge">✦ Nouveau</div>
			<h1>Bienvenue sur<br/><span class="gradient-text">NeoSomaTech</span></h1>
			<p class="hero-sub">Explorez notre boutique et découvrez des produits soigneusement sélectionnés.</p>
			<div class="hero-actions">
				<a href="/boutique" class="btn">Voir la boutique &rarr;</a>
				<a href="/a-propos" class="btn btn-outline">En savoir plus</a>
			</div>
		</div>
	</section>

	<!-- PRODUITS -->
	<section class="products-section container">
		<div class="section-header">
			<h2>Nos Produits</h2>
			<p>Une sélection récupérée en direct depuis notre base de données.</p>
		</div>

		{errorMessage ? (
			<div class="error-box">
				<strong>⚠️ Erreur de connexion :</strong> {errorMessage}
			</div>
		) : produits.length === 0 ? (
			<div class="empty-box">
				<p>Aucun produit trouvé. Vérifiez votre connexion à Directus.</p>
			</div>
		) : (
			<div class="grid">
				{produits.map((produit) => (
					<article class="card">
						<div class="card-tag">Produit</div>
						<h3>{produit.Nom_du_produit}</h3>
						<p class="card-desc">{produit.descripton_simple}</p>
						<div class="card-footer">
							<span class="price">
								{produit.prix ? `${produit.prix} €` : 'Prix sur demande'}
							</span>
							<a href={`/produits/${produit.id}`} class="btn">
								Voir &rarr;
							</a>
						</div>
					</article>
				))}
			</div>
		)}
	</section>
</Layout>

<style>
	/* ---- HERO ---- */
	.hero {
		position: relative;
		overflow: hidden;
		padding: 7rem 0 5rem;
		text-align: center;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99,102,241,0.18) 0%, transparent 70%);
		pointer-events: none;
	}
	.hero-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}
	.hero-badge {
		display: inline-block;
		background: rgba(99,102,241,0.15);
		border: 1px solid rgba(99,102,241,0.4);
		color: #a5b4fc;
		font-size: 0.8rem;
		font-weight: 600;
		padding: 0.3rem 0.9rem;
		border-radius: 99px;
		letter-spacing: 1px;
		text-transform: uppercase;
	}
	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 900;
		color: #fff;
		line-height: 1.1;
		letter-spacing: -2px;
	}
	.gradient-text {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-sub {
		font-size: 1.2rem;
		color: var(--text-light);
		max-width: 520px;
		line-height: 1.6;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	/* ---- PRODUCTS SECTION ---- */
	.products-section {
		padding: 4rem 1.5rem 6rem;
	}
	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}
	.section-header h2 {
		font-size: 2rem;
		font-weight: 800;
		color: #fff;
		margin-bottom: 0.5rem;
	}
	.section-header p {
		color: var(--text-light);
		font-size: 1.05rem;
	}

	/* ---- GRID ---- */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
	}
	.card:hover {
		transform: translateY(-5px);
		border-color: var(--primary);
		box-shadow: 0 0 30px rgba(99, 102, 241, 0.15);
	}
	.card-tag {
		font-size: 0.75rem;
		font-weight: 600;
		color: #818cf8;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.card h3 {
		font-size: 1.3rem;
		font-weight: 700;
		color: #fff;
		line-height: 1.3;
	}
	.card-desc {
		color: var(--text-light);
		font-size: 0.95rem;
		line-height: 1.6;
		flex: 1;
	}
	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.5rem;
	}
	.price {
		font-size: 1.5rem;
		font-weight: 800;
		color: #818cf8;
	}

	/* ---- UTILS ---- */
	.error-box {
		background: rgba(239, 68, 68, 0.1);
		border: 1px solid rgba(239, 68, 68, 0.3);
		color: #fca5a5;
		padding: 1.5rem;
		border-radius: 12px;
		text-align: center;
	}
	.empty-box {
		background: var(--surface);
		border: 1px dashed var(--border);
		padding: 3rem;
		border-radius: 12px;
		text-align: center;
		color: var(--text-light);
	}
</style>