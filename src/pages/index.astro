---
import Layout from '../layouts/Layout.astro';
import { directus } from '../lib/directus';
import { readItems } from '@directus/sdk';

let produits = [];
try {
    produits = await directus.request(
        readItems('Produits', {
            limit: 10,
            fields: ['id', 'Nom_du_produit', 'prix', 'descripton_simple']
        })
    );
} catch (error) {
    console.error("Erreur lors de la récupération des produits Directus:", error);
}
---

<Layout title="Accueil - NeoSomaTech">
	<section class="hero">
        <h1>Découvrez nos Produits</h1>
        <p>Une sélection de produits récupérés en temps réel depuis Directus.</p>
    </section>

    <section class="products">
        {produits.length === 0 ? (
            <div class="empty-state">
                <p>Aucun produit trouvé ou erreur de connexion à Directus.</p>
                <small>Assurez-vous que la collection "Produits" existe et contient des éléments publics ou que votre token est valide.</small>
            </div>
        ) : (
            <div class="grid">
                {produits.map((produit) => (
                    <div class="card">
                        <div class="card-content">
                            <h3>{produit.Nom_du_produit}</h3>
                            <p class="desc">{produit.descripton_simple}</p>
                            <p class="price">{produit.prix ? `${produit.prix} €` : 'Prix sur demande'}</p>
                        </div>
                        <a href={`/produits/${produit.id}`} class="btn">Voir les détails</a>
                    </div>
                ))}
            </div>
        )}
    </section>
</Layout>

<style>
    .hero {
        text-align: center;
        padding: 4rem 1rem;
        background: var(--card-bg);
        border-radius: 16px;
        margin-bottom: 3rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    }
    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: var(--primary);
        font-weight: 800;
        letter-spacing: -1px;
    }
    .hero p {
        font-size: 1.25rem;
        color: var(--text-light);
    }
    .products h2 {
        font-size: 2rem;
        margin-bottom: 2rem;
        text-align: center;
        font-weight: 700;
    }
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
    }
    .card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid var(--border);
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        border-color: var(--primary-hover);
    }
    .card-content {
        flex: 1;
    }
    .card h3 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--text);
    }
    .desc {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }
    .price {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 1.5rem;
    }
    .btn {
        width: 100%;
    }
    .empty-state {
        text-align: center;
        padding: 3rem;
        background: #fee2e2;
        color: #991b1b;
        border-radius: 12px;
    }
    .empty-state small {
        display: block;
        margin-top: 1rem;
        color: #7f1d1d;
    }
</style>