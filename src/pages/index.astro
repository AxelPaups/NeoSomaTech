---
import Layout from "../layouts/Layout.astro";
import { fetchDirectus } from "../lib/directus";

let produits: any[] = [];
let articles: any[] = [];
let errorMessage: string | null = null;

try {
	[produits, articles] = await Promise.all([
		fetchDirectus(
			"/items/Produits?limit=6&fields=id,Nom_du_produit,prix,descripton_simple,slug,image",
		),
		fetchDirectus(
			"/items/Articles?limit=3&sort=-date_publication&fields=id,titre,slug,description_seo,date_publication,auteur,image_principale",
		),
	]);
} catch (error: any) {
	console.error("Erreur Directus:", error);
	errorMessage = error.message;
}

const directusUrl = "https://spirited-squid.pikapod.net";
const formatDate = (date: string) =>
	date
		? new Intl.DateTimeFormat("fr-FR", {
				year: "numeric",
				month: "long",
				day: "numeric",
			}).format(new Date(date))
		: "";
---

<Layout
	title="NeoSomaTech - Exosquelettes & Innovations"
	description="NeoSomaTech : boutique et blog dédiés aux exosquelettes. Comparatifs, guides d'achat et dernières innovations."
>
	<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "NeoSomaTech",
			"url": "https://neosomatech.com",
			"description": "NeoSomaTech : boutique et blog dédiés aux exosquelettes. Comparatifs, guides d'achat et dernières innovations.",
			"publisher": {
				"@type": "Organization",
				"name": "NeoSomaTech",
				"logo": {
					"@type": "ImageObject",
					"url": "https://neosomatech.com/favicon.png"
				}
			}
		}
	</script>
	<!-- ===== HERO ===== -->
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="container hero-content">
			<div class="hero-badge">✦ Spécialiste Exosquelettes</div>
			<h1>
				L'avenir du corps<br /><span class="gradient-text"
					>commence ici</span
				>
			</h1>
			<p class="hero-sub">
				Découvrez une sélection d'exosquelettes de pointe et lisez nos
				analyses approfondies pour faire le meilleur choix.
			</p>
			<div class="hero-actions">
				<a href="/boutique" class="btn">Voir les produits &rarr;</a>
				<a href="/articles" class="btn btn-outline">Lire nos articles</a
				>
			</div>
		</div>
	</section>

	<!-- ===== MISSION ===== -->
	<section class="mission-section">
		<div class="container mission-inner">
			<div class="mission-text">
				<span class="section-label">Notre mission</span>
				<h2>L'exosquelette accessible à tous</h2>
				<p>
					NeoSomaTech est la référence francophone dédiée aux <strong
						>exosquelettes médicaux, industriels et sportifs</strong
					>. Notre équipe d'experts analyse, compare et sélectionne
					les meilleures solutions pour augmenter les capacités
					humaines — que vous soyez professionnel de santé, industriel
					ou sportif en quête de mobilité retrouvée.
				</p>
				<p>
					Chaque produit référencé sur notre boutique est
					soigneusement évalué selon des critères de <strong
						>performance, sécurité et ergonomie</strong
					>. Nos guides et comparatifs approfondis vous permettent de
					choisir en toute confiance.
				</p>
			</div>
			<div class="mission-pillars">
				<div class="pillar">
					<div class="pillar-icon">🔬</div>
					<h3>Expertise technique</h3>
					<p>
						Des analyses détaillées rédigées par des spécialistes en
						robotique et biomécanique.
					</p>
				</div>
				<div class="pillar">
					<div class="pillar-icon">⚡</div>
					<h3>Innovation continue</h3>
					<p>
						Nous suivons les dernières avancées pour vous présenter
						les technologies les plus récentes du marché.
					</p>
				</div>
				<div class="pillar">
					<div class="pillar-icon">🤝</div>
					<h3>Accompagnement personnalisé</h3>
					<p>
						Notre équipe répond à vos questions pour trouver
						l'exosquelette adapté à votre situation.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== PRODUITS ===== -->
	<section class="section container">
		<div class="section-header">
			<span class="section-label">Sélection Exclusive</span>
			<h2>Nos Exosquelettes</h2>
			<p>L'alliance parfaite de la technologie et du mouvement.</p>
		</div>

		{
			errorMessage ? (
				<div class="error-box">
					<strong>⚠️</strong> {errorMessage}
				</div>
			) : produits.length === 0 ? (
				<div class="empty-box">
					<p>Aucun produit pour le moment.</p>
				</div>
			) : (
				<div class="products-grid">
					{produits.map((produit) => (
						<article class="product-card">
							<div class="product-img-wrapper">
								{produit.image ? (
									<img
										src={`${directusUrl}/assets/${produit.image}`}
										alt={produit.Nom_du_produit}
										loading="lazy"
									/>
								) : (
									<div class="img-placeholder">🦾</div>
								)}
								<div class="product-badge">Top Product</div>
							</div>
							<div class="product-info">
								<div class="product-tag">Exosquelette</div>
								<h3>{produit.Nom_du_produit}</h3>
								<p class="product-desc">
									{produit.descripton_simple}
								</p>
								<div class="product-footer">
									<div class="price-container">
										<span class="price-label">À partir de</span>
										<span class="price">
											{produit.prix
												? `${produit.prix} €`
												: "Sur devis"}
										</span>
									</div>
									<a
										href={`/produits/${produit.slug || produit.id}`}
										class="btn-icon"
										aria-label={`Voir ${produit.Nom_du_produit}`}
									>
										&rarr;
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
			)
		}
		<div class="section-footer">
			<a href="/boutique" class="btn btn-outline">Découvrir toute la boutique &rarr;</a>
		</div>
	</section>

	<!-- ===== ARTICLES ===== -->
	{
		articles.length > 0 && (
			<section class="section articles-section">
				<div class="container">
					<div class="section-header">
						<h2>Derniers Articles</h2>
						<p>
							Guides, comparatifs et actualités sur les
							exosquelettes.
						</p>
						<a href="/articles" class="see-all">
							Voir tous les articles &rarr;
						</a>
					</div>
					<div class="articles-grid">
						{articles.map((article) => (
							<article class="article-card">
								{article.image_principale && (
									<a
										href={`/articles/${article.slug}`}
										class="article-img"
									>
										<img
											src={`${directusUrl}/assets/${article.image_principale}`}
											alt={article.titre}
											loading="lazy"
										/>
									</a>
								)}
								<div class="article-body">
									<div class="article-meta">
										{article.date_publication && (
											<time>
												{formatDate(
													article.date_publication,
												)}
											</time>
										)}
										{article.auteur && (
											<span>· {article.auteur}</span>
										)}
									</div>
									<h3>
										<a href={`/articles/${article.slug}`}>
											{article.titre}
										</a>
									</h3>
									{article.description_seo && (
										<p class="article-excerpt">
											{article.description_seo}
										</p>
									)}
									<a
										href={`/articles/${article.slug}`}
										class="read-link"
									>
										Lire la suite &rarr;
									</a>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- ===== CTA FINAL ===== -->
	<section class="cta-section container">
		<div class="cta-box">
			<h2>Une question sur les exosquelettes ?</h2>
			<p>
				Notre équipe est disponible pour vous conseiller dans votre
				choix.
			</p>
			<a href="/contact" class="btn">Nous contacter &rarr;</a>
		</div>
	</section>
</Layout>

<style>
	/* HERO */
	.hero {
		position: relative;
		overflow: hidden;
		padding: 8rem 0 5rem;
		text-align: center;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse 100% 70% at 50% 0%,
			rgba(99, 102, 241, 0.22) 0%,
			transparent 70%
		);
		pointer-events: none;
	}
	.hero-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}
	.hero-badge {
		display: inline-block;
		background: rgba(99, 102, 241, 0.15);
		border: 1px solid rgba(99, 102, 241, 0.4);
		color: #a5b4fc;
		font-size: 0.78rem;
		font-weight: 600;
		padding: 0.3rem 0.9rem;
		border-radius: 99px;
		letter-spacing: 1px;
		text-transform: uppercase;
	}
	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 900;
		color: #fff;
		line-height: 1.1;
		letter-spacing: -2px;
	}
	.gradient-text {
		background: linear-gradient(
			135deg,
			#6366f1 0%,
			#8b5cf6 50%,
			#ec4899 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-sub {
		font-size: 1.15rem;
		color: var(--text-light);
		max-width: 560px;
		line-height: 1.65;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	/* MISSION */
	.mission-section {
		padding: 6rem 0;
		background: linear-gradient(
			to bottom,
			transparent,
			var(--surface-2) 50%,
			transparent
		);
	}
	.mission-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	.section-label {
		display: inline-block;
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		font-size: 0.8rem;
		margin-bottom: 1rem;
	}
	.mission-text h2 {
		font-size: 2.5rem;
		font-weight: 800;
		color: #fff;
		line-height: 1.2;
		margin-bottom: 1.5rem;
	}
	.mission-text p {
		color: var(--text-light);
		font-size: 1.1rem;
		line-height: 1.7;
		margin-bottom: 1.2rem;
	}
	.mission-pillars {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}
	.pillar {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}
	.pillar-icon {
		font-size: 2rem;
		background: var(--surface);
		border: 1px solid var(--border);
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		flex-shrink: 0;
	}
	.pillar h3 {
		font-size: 1.15rem;
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.4rem;
	}
	.pillar p {
		color: var(--text-light);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 992px) {
		.mission-inner {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		.mission-text {
			text-align: center;
		}
	}

	/* SECTIONS */
	.section {
		padding: 4rem 0;
	}
	.articles-section {
		background: var(--surface-2);
	}
	.section-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}
	.section-header h2 {
		font-size: 2rem;
		font-weight: 800;
		color: #fff;
		margin-bottom: 0.4rem;
	}
	.section-header p {
		color: var(--text-light);
		font-size: 1rem;
		margin-bottom: 0.75rem;
	}
	.see-all {
		font-size: 0.9rem;
		font-weight: 600;
		color: #818cf8;
		text-decoration: none;
		transition: color 0.2s;
	}
	.see-all:hover {
		color: #a5b4fc;
	}

	/* PRODUCTS */
	.products-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}
	.product-card {
		background: rgba(26, 26, 46, 0.6);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(99, 102, 241, 0.2);
		border-radius: 24px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}
	.product-card:hover {
		transform: translateY(-12px) scale(1.02);
		border-color: rgba(99, 102, 241, 0.6);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(99, 102, 241, 0.2);
	}
	.product-img-wrapper {
		position: relative;
		aspect-ratio: 1/1;
		overflow: hidden;
		background: #000;
	}
	.product-img-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.product-card:hover .product-img-wrapper img {
		transform: scale(1.1);
	}
	.img-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 4rem;
		background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
		color: rgba(99, 102, 241, 0.3);
	}
	.product-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: var(--gradient);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.4rem 0.8rem;
		border-radius: 99px;
		box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.product-info {
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		flex: 1;
	}
	.product-tag {
		font-size: 0.7rem;
		font-weight: 700;
		color: #818cf8;
		text-transform: uppercase;
		letter-spacing: 1.5px;
	}
	.product-card h3 {
		font-size: 1.4rem;
		font-weight: 800;
		color: #fff;
		line-height: 1.25;
	}
	.product-desc {
		color: var(--text-light);
		font-size: 0.95rem;
		line-height: 1.6;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.product-footer {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-top: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}
	.price-container {
		display: flex;
		flex-direction: column;
	}
	.price-label {
		font-size: 0.75rem;
		color: var(--text-light);
		font-weight: 500;
	}
	.price {
		font-size: 1.6rem;
		font-weight: 900;
		color: #fff;
		background: var(--gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.btn-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(99, 102, 241, 0.1);
		color: #fff;
		border-radius: 12px;
		text-decoration: none;
		font-size: 1.5rem;
		transition: all 0.3s ease;
		border: 1px solid rgba(99, 102, 241, 0.2);
	}
	.product-card:hover .btn-icon {
		background: var(--gradient);
		transform: rotate(-45deg);
		box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
	}
	.section-footer {
		text-align: center;
		margin-top: 1rem;
	}

	/* ARTICLES */
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.article-card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 16px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition:
			transform 0.2s,
			border-color 0.2s;
	}
	.article-card:hover {
		transform: translateY(-5px);
		border-color: var(--primary);
	}
	.article-img {
		display: block;
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.article-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s;
	}
	.article-card:hover .article-img img {
		transform: scale(1.04);
	}
	.article-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		flex: 1;
	}
	.article-meta {
		font-size: 0.8rem;
		color: var(--text-light);
		display: flex;
		gap: 0.4rem;
	}
	.article-body h3 {
		font-size: 1.1rem;
		font-weight: 700;
		color: #fff;
		line-height: 1.35;
	}
	.article-body h3 a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s;
	}
	.article-body h3 a:hover {
		color: #a5b4fc;
	}
	.article-excerpt {
		color: var(--text-light);
		font-size: 0.88rem;
		line-height: 1.6;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.read-link {
		font-size: 0.88rem;
		font-weight: 600;
		color: #818cf8;
		text-decoration: none;
		transition: color 0.2s;
	}
	.read-link:hover {
		color: #a5b4fc;
	}

	/* CTA */
	.cta-section {
		padding: 4rem 1.5rem 6rem;
	}
	.cta-box {
		background: linear-gradient(
			135deg,
			rgba(99, 102, 241, 0.15) 0%,
			rgba(139, 92, 246, 0.15) 100%
		);
		border: 1px solid rgba(99, 102, 241, 0.3);
		border-radius: 20px;
		padding: 3.5rem 2rem;
		text-align: center;
	}
	.cta-box h2 {
		font-size: 1.8rem;
		font-weight: 800;
		color: #fff;
		margin-bottom: 0.75rem;
	}
	.cta-box p {
		color: var(--text-light);
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
	}

	.error-box {
		background: rgba(239, 68, 68, 0.1);
		border: 1px solid rgba(239, 68, 68, 0.3);
		color: #fca5a5;
		padding: 1.5rem;
		border-radius: 12px;
		text-align: center;
	}
	.empty-box {
		background: var(--surface);
		border: 1px dashed var(--border);
		padding: 3rem;
		border-radius: 12px;
		text-align: center;
		color: var(--text-light);
	}
</style>
