---
import Layout from '../layouts/Layout.astro';
import { fetchDirectus } from '../lib/directus';

const directusUrl = "https://spirited-squid.pikapod.net";

let products: any[] = [];
let errorMessage: string | null = null;

try {
    // fields to request, including the new ones the user will add + variantes
    const query = `/items/Produits?fields=id,Nom_du_produit,nom_court,slug,image,prix,marque,poids,autonomie,assistance_max,temps_charge,materiaux,garantie,certification,comparateur_defaut,variantes.*&limit=50`;
    const data = await fetchDirectus(query);
    products = Array.isArray(data) ? data : [];
} catch (error: any) {
    console.error("Erreur lors de la récupération des produits :", error);
    errorMessage = error.message;
}

// Prepare data for the client
const flatOptions: any[] = [];

products.forEach(p => {
    // Produit principal
    flatOptions.push({
        id: p.id,
        nom: p.Nom_du_produit,
        nom_court: p.nom_court,
        slug: p.slug,
        image: p.image ? `${directusUrl}/assets/${p.image}` : null,
        prix: p.prix,
        marque: p.marque,
        poids: p.poids || 'N/A',
        autonomie: p.autonomie || 'N/A',
        assistance_max: p.assistance_max || 'N/A',
        temps_charge: p.temps_charge || 'N/A',
        materiaux: p.materiaux || 'N/A',
        garantie: p.garantie || 'N/A',
        certification: p.certification || 'N/A',
        comparateur_defaut: p.comparateur_defaut === true || p.comparateur_defaut === 'true' || p.comparateur_defaut === 1 || p.comparateur_defaut === '1'
    });

    // Ses variantes
    if (p.variantes && p.variantes.length > 0) {
        p.variantes.forEach((v: any) => {
            flatOptions.push({
                id: `v_${v.id}`,
                nom: v.Nom_du_produit || p.Nom_du_produit,
                nom_court: v.nom_court || v.Nom_du_produit,
                parent_nom: p.nom_court || p.Nom_du_produit,
                slug: p.slug,
                image: v.Image ? `${directusUrl}/assets/${v.Image}` : (p.image ? `${directusUrl}/assets/${p.image}` : null),
                prix: v.prix || p.prix,
                marque: p.marque,
                poids: v.poids || p.poids || 'N/A',
                autonomie: v.autonomie || p.autonomie || 'N/A',
                assistance_max: v.assistance_max || p.assistance_max || 'N/A',
                temps_charge: v.temps_charge || p.temps_charge || 'N/A',
                materiaux: v.materiaux || p.materiaux || 'N/A',
                garantie: v.garantie || p.garantie || 'N/A',
                certification: v.certification || p.certification || 'N/A',
                comparateur_defaut: false
            });
        });
    }
});

const productsJson = JSON.stringify(flatOptions);

---

<Layout title="Comparateur de produits | NeoSomaTech" description="Comparez nos différents exosquelettes pour trouver celui qui correspond à vos besoins.">
    <div class="page-wrapper container">
        <header class="comparateur-header">
            <h1 class="main-title">Comparateur <span class="gradient-text">de Produits</span></h1>
            <p class="subtitle">Sélectionnez jusqu'à 3 produits pour comparer leurs caractéristiques en détail.</p>
        </header>

        {errorMessage ? (
            <div class="error-box">⚠️ {errorMessage}</div>
        ) : products.length === 0 ? (
            <div class="empty-box">Aucun produit disponible pour la comparaison.</div>
        ) : (
            <div class="comparateur-grid" id="comparateur-app" data-products={productsJson}>
                <!-- Les 3 colonnes de comparaison -->
                {[0, 1, 2].map((colIndex) => (
                    <div class="compare-col" data-col={colIndex}>
                        <div class="custom-select-wrapper">
                            <div class="custom-select" id={`select-col-${colIndex}`}>
                                <div class="select-trigger">
                                    <span class="trigger-text">-- Sélectionner un produit --</span>
                                    <span class="arrow">▼</span>
                                </div>
                                <div class="select-options-container">
                                    <div class="select-options">
                                        <div class="select-option" data-value="">-- Sélectionner un produit --</div>
                                        {flatOptions.map((p) => (
                                            <div class="select-option" data-value={p.id}>
                                                {p.parent_nom ? `${p.parent_nom} - ${p.nom_court}` : (p.nom_court || p.nom)}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="product-card empty">
                            <img src="/favicon.png" alt="NST Logo" class="placeholder-logo" />
                            <p>Sélectionnez un produit</p>
                        </div>

                        <div class="product-card filled" style="display: none;">
                            <div class="product-img-wrapper">
                                <img src="" alt="" class="product-img" />
                            </div>
                            
                            <div class="product-info-top">
                                <div class="brand-tag"></div>
                                <h2 class="product-name"></h2>
                                <div class="product-price"></div>
                                <a href="#" class="btn btn-buy btn-small">Voir le produit</a>
                            </div>

                            <div class="product-specs">
                                <div class="spec-row">
                                    <span class="spec-label">Poids</span>
                                    <span class="spec-val" data-field="poids"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Autonomie</span>
                                    <span class="spec-val" data-field="autonomie"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Assistance max.</span>
                                    <span class="spec-val" data-field="assistance_max"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Temps de charge</span>
                                    <span class="spec-val" data-field="temps_charge"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Matériaux</span>
                                    <span class="spec-val" data-field="materiaux"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Garantie</span>
                                    <span class="spec-val" data-field="garantie"></span>
                                </div>
                                <div class="spec-row">
                                    <span class="spec-label">Certification</span>
                                    <span class="spec-val" data-field="certification"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        )}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const app = document.getElementById('comparateur-app');
            if (!app) return;

            const productsData = JSON.parse(app.getAttribute('data-products') || '[]');
            const cols = app.querySelectorAll('.compare-col');

            // Set default products based on 'comparateur_defaut' flag
            let defaultIds = productsData.filter((p: any) => p.comparateur_defaut).map((p: any) => String(p.id));
            if (defaultIds.length < 3) {
                const otherIds = productsData.filter((p: any) => !p.comparateur_defaut).map((p: any) => String(p.id));
                defaultIds = [...defaultIds, ...otherIds].slice(0, 3);
            }
            const defaults = defaultIds.slice(0, 3);

            cols.forEach((col, index) => {
                const customSelect = col.querySelector('.custom-select') as HTMLElement;
                const trigger = customSelect.querySelector('.select-trigger') as HTMLElement;
                const triggerText = trigger.querySelector('.trigger-text') as HTMLElement;
                const options = customSelect.querySelectorAll('.select-option');
                
                const emptyCard = col.querySelector('.product-card.empty') as HTMLElement;
                const filledCard = col.querySelector('.product-card.filled') as HTMLElement;

                // Toggle dropdown
                trigger.addEventListener('click', (e) => {
                    e.stopPropagation();
                    document.querySelectorAll('.custom-select').forEach(s => {
                        if (s !== customSelect) s.classList.remove('open');
                    });
                    customSelect.classList.toggle('open');
                });

                // Close when clicking outside
                document.addEventListener('click', () => {
                    customSelect.classList.remove('open');
                });

                // Update UI function
                const updateCard = (productId: string) => {
                    if (!productId) {
                        emptyCard.style.display = 'flex';
                        filledCard.style.display = 'none';
                        return;
                    }

                    const product = productsData.find((p: any) => String(p.id) === String(productId));
                    if (!product) return;

                    emptyCard.style.display = 'none';
                    filledCard.style.display = 'flex';

                    // Update Image
                    const img = filledCard.querySelector('.product-img') as HTMLImageElement;
                    if (product.image) {
                        img.src = product.image;
                        img.style.display = 'block';
                    } else {
                        img.style.display = 'none';
                    }

                    // Update Top Info
                    const brandTag = filledCard.querySelector('.brand-tag') as HTMLElement;
                    if (product.marque) {
                        brandTag.textContent = product.marque;
                        brandTag.style.opacity = '1';
                    } else {
                        brandTag.textContent = 'X';
                        brandTag.style.opacity = '0';
                    }

                    (filledCard.querySelector('.product-name') as HTMLElement).textContent = product.nom;
                    (filledCard.querySelector('.product-price') as HTMLElement).textContent = product.prix ? `${product.prix} €` : 'Contact';
                    (filledCard.querySelector('.btn-buy') as HTMLAnchorElement).href = `/produits/${product.slug}`;

                    // Update Specs
                    const setSpec = (field: string, val: string) => {
                        const el = filledCard.querySelector(`[data-field="${field}"]`) as HTMLElement;
                        if (el) el.textContent = val || 'N/A';
                    };
                    
                    setSpec('poids', product.poids);
                    setSpec('autonomie', product.autonomie);
                    setSpec('assistance_max', product.assistance_max);
                    setSpec('temps_charge', product.temps_charge);
                    setSpec('materiaux', product.materiaux);
                    setSpec('garantie', product.garantie);
                    setSpec('certification', product.certification);
                };

                // Handle option selection
                options.forEach(opt => {
                    opt.addEventListener('click', () => {
                        const val = opt.getAttribute('data-value') || '';
                        triggerText.textContent = opt.textContent;
                        updateCard(val);
                        customSelect.classList.remove('open');
                        
                        options.forEach(o => o.classList.remove('selected'));
                        opt.classList.add('selected');
                    });
                });

                // Apply defaults
                if (defaults[index]) {
                    const defaultOpt = Array.from(options).find(o => o.getAttribute('data-value') === String(defaults[index]));
                    if (defaultOpt) {
                        triggerText.textContent = defaultOpt.textContent;
                        defaultOpt.classList.add('selected');
                        updateCard(defaults[index]);
                    }
                }
            });
        });
    </script>

    <style>
        .page-wrapper {
            padding-top: 4rem;
            padding-bottom: 6rem;
        }

        .comparateur-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .subtitle {
            color: var(--text-light);
            font-size: 1.1rem;
            margin-top: 1rem;
        }

        /* GRID DES COLONNES */
        .comparateur-grid {
            display: grid;
            grid-template-columns: repeat(1, 1fr);
            gap: 2rem;
            align-items: flex-start;
        }

        @media (min-width: 768px) {
            .comparateur-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .compare-col {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            min-width: 0;
            height: 100%;
        }

        /* CUSTOM SELECT PREMIUM */
        .custom-select-wrapper {
            position: relative;
            z-index: 50;
        }
        .custom-select {
            position: relative;
            width: 100%;
        }
        .select-trigger {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.25rem;
            background: rgba(26, 26, 46, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            user-select: none;
        }
        .custom-select:hover .select-trigger {
            border-color: var(--primary);
            box-shadow: 0 4px 20px rgba(99, 102, 241, 0.15);
        }
        .custom-select.open .select-trigger {
            border-color: var(--primary);
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
            background: var(--surface);
        }
        .select-trigger .arrow {
            font-size: 0.7rem;
            transition: transform 0.3s ease;
            color: var(--text-light);
        }
        .custom-select.open .arrow {
            transform: rotate(180deg);
        }

        .select-options-container {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #1a1a2e;
            border: 1px solid var(--primary);
            border-top: none;
            border-bottom-left-radius: 12px;
            border-bottom-right-radius: 12px;
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 100;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
        }
        .custom-select.open .select-options-container {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .select-options {
            max-height: 250px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--primary) transparent;
        }
        .select-options::-webkit-scrollbar {
            width: 6px;
        }
        .select-options::-webkit-scrollbar-thumb {
            background-color: var(--primary);
            border-radius: 10px;
        }

        .select-option {
            padding: 0.9rem 1.25rem;
            color: var(--text-light);
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.95rem;
            border-left: 3px solid transparent;
        }
        .select-option:hover {
            background: rgba(99, 102, 241, 0.1);
            color: #fff;
            border-left-color: var(--primary);
            padding-left: 1.5rem;
        }
        .select-option.selected {
            background: rgba(99, 102, 241, 0.2);
            color: #fff;
            font-weight: 700;
            border-left-color: var(--primary);
        }

        /* CARTES PRODUIT */
        .product-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            flex-direction: column;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease, border-color 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        .product-card:hover {
            border-color: rgba(99, 102, 241, 0.5);
            transform: translateY(-5px);
        }

        .product-card.empty {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            padding-top: 8rem;
            padding-left: 2rem;
            padding-right: 2rem;
            border: 1px dashed var(--border);
            background: transparent;
            box-shadow: none;
            color: var(--text-light);
            text-align: center;
            gap: 1rem;
        }
        .placeholder-logo {
            width: 4rem;
            height: 4rem;
            object-fit: contain;
            filter: brightness(0) invert(1);
            opacity: 0.15;
            margin-bottom: 0.5rem;
        }

        .product-img-wrapper {
            width: 100%;
            aspect-ratio: 1/1;
            background: #1a1a2e;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid var(--border);
            padding: 1.5rem;
        }
        .product-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: transform 0.5s ease;
        }
        .product-card:hover .product-img {
            transform: scale(1.05);
        }
        .product-info-top {
            padding: 1.5rem;
            text-align: center;
            border-bottom: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        .brand-tag {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #818cf8;
            font-weight: 700;
            min-height: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s;
        }
        .product-name {
            font-size: 1.15rem;
            font-weight: 800;
            color: #fff;
            margin: 0;
            line-height: 1.3;
            height: 4.6rem; /* Hauteur fixe pour 3 lignes pour tout aligner */
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow: hidden;
        }

        .product-price {
            font-size: 1.5rem;
            font-weight: 900;
            color: #fff;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .btn-small {
            padding: 0.6rem 1.5rem;
            font-size: 0.9rem;
            margin-top: 0.5rem;
            width: 100%;
            text-align: center;
            border-radius: 8px;
        }

        /* SPECS */
        .product-specs {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            flex-grow: 1;
        }
        .spec-row {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
        }
        .spec-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
        .spec-label {
            font-size: 0.85rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        }
        .spec-val {
            font-size: 1.05rem;
            color: #fff;
            font-weight: 500;
        }
    </style>
</Layout>
