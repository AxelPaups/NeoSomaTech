---
// page : /articles
// Liste de tous les articles, optimisée SEO
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus } from '../../lib/directus';

let articles: any[] = [];
let errorMessage: string | null = null;

try {
    articles = await fetchDirectus(
        '/items/Articles?sort=-date_publication&fields=id,titre,slug,description_seo,date_publication,auteur,image_principale'
    );
} catch (error: any) {
    console.error("Erreur Articles:", error);
    errorMessage = error.message;
}

const formatDate = (date: string) => {
    if (!date) return '';
    return new Intl.DateTimeFormat('fr-FR', { year:'numeric', month:'long', day:'numeric' }).format(new Date(date));
};
---

<Layout
    title="Articles sur les Exosquelettes | NeoSomaTech"
    description="Découvrez nos articles de fond sur les exosquelettes : ski, travail, médical, innovations. Restez informé des dernières avancées."
>
    <div class="page-wrapper">
        <!-- EN-TÊTE DE PAGE -->
        <header class="page-header container">
            <div class="breadcrumb"><a href="/">Accueil</a> / Articles</div>
            <h1>Articles & <span class="gradient-text">Actualités</span></h1>
            <p>Tout savoir sur les exosquelettes : comparatifs, guides, innovations et avis d'experts.</p>
        </header>

        <!-- GRILLE ARTICLES -->
        <div class="container articles-content">
            {errorMessage ? (
                <div class="error-box">
                    <strong>⚠️ Erreur :</strong> {errorMessage}
                </div>
            ) : articles.length === 0 ? (
                <div class="empty-box">
                    <p>Aucun article publié pour le moment. Revenez bientôt !</p>
                </div>
            ) : (
                <div class="articles-grid">
                    {articles.map((article, i) => (
                        <article class:list={["article-card", { featured: i === 0 }]}>
                            {article.image_principale && (
                                <div class="card-img">
                                    <img
                                        src={`https://spirited-squid.pikapod.net/assets/${article.image_principale}`}
                                        alt={article.titre}
                                        loading={i === 0 ? 'eager' : 'lazy'}
                                    />
                                </div>
                            )}
                            <div class="card-body">
                                <div class="card-meta">
                                    {article.date_publication && (
                                        <time datetime={article.date_publication}>
                                            {formatDate(article.date_publication)}
                                        </time>
                                    )}
                                    {article.auteur && <span class="author">par {article.auteur}</span>}
                                </div>
                                <h2><a href={`/articles/${article.slug}`}>{article.titre}</a></h2>
                                {article.description_seo && (
                                    <p class="card-excerpt">{article.description_seo}</p>
                                )}
                                <a href={`/articles/${article.slug}`} class="read-more">
                                    Lire l'article <span>&rarr;</span>
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            )}
        </div>
    </div>
</Layout>

<style>
    .page-wrapper { padding-bottom: 5rem; }

    .page-header {
        padding: 4rem 1.5rem 3rem;
        text-align: center;
    }
    .breadcrumb {
        font-size: 0.85rem;
        color: var(--text-light);
        margin-bottom: 1rem;
    }
    .breadcrumb a { color: #818cf8; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .page-header h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        color: #fff;
        letter-spacing: -1.5px;
        margin-bottom: 0.75rem;
    }
    .page-header p {
        color: var(--text-light);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* GRILLE */
    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.5rem;
    }

    /* Card standard */
    .article-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .article-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: 0 0 30px rgba(99, 102, 241, 0.15);
    }

    /* Première carte en vedette sur toute la largeur */
    .article-card.featured {
        grid-column: 1 / -1;
        flex-direction: row;
    }
    .article-card.featured .card-img {
        flex: 0 0 45%;
    }
    .article-card.featured h2 { font-size: 1.6rem; }

    .card-img {
        overflow: hidden;
        aspect-ratio: 16/9;
    }
    .card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }
    .article-card:hover .card-img img { transform: scale(1.04); }

    .card-body {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        flex: 1;
    }
    .card-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.82rem;
        color: var(--text-light);
    }
    .author { color: #818cf8; }
    .card-body h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.35;
    }
    .card-body h2 a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }
    .card-body h2 a:hover { color: #a5b4fc; }
    .card-excerpt {
        color: var(--text-light);
        font-size: 0.95rem;
        line-height: 1.6;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .read-more {
        font-size: 0.9rem;
        font-weight: 600;
        color: #818cf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: gap 0.2s, color 0.2s;
    }
    .read-more:hover { color: #a5b4fc; gap: 0.6rem; }

    .error-box {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #fca5a5;
        padding: 1.5rem;
        border-radius: 12px;
        text-align: center;
    }
    .empty-box {
        background: var(--surface);
        border: 1px dashed var(--border);
        padding: 3rem;
        border-radius: 12px;
        text-align: center;
        color: var(--text-light);
    }

    @media (max-width: 700px) {
        .article-card.featured { flex-direction: column; }
    }
</style>
