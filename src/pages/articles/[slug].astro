---
// page : /articles/[slug]
// Page article avec SEO maximum : meta, og:, json-ld
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus } from '../../lib/directus';
import { linkifyProducts } from '../../lib/linkifyProducts';

const { slug } = Astro.params;

let article: any = null;
let errorMessage: string | null = null;
let productsForLinking: { name: string, slug: string }[] = [];

try {
    // 1. Récupérer l'article
    const data = await fetchDirectus(
        `/items/Articles?filter[slug][_eq]=${slug}&fields=id,titre,slug,description_seo,meta_description,contenu,date_publication,auteur,image_principale&limit=1`
    );
    article = Array.isArray(data) ? data[0] : data;

    // 2. Récupérer tous les produits pour les liens automatiques
    if (article) {
        const productsData = await fetchDirectus(`/items/Produits?fields=Nom_du_produit,nom_court,slug&limit=100`);
        if (Array.isArray(productsData)) {
            productsData.forEach((p: any) => {
                // On ajoute le nom complet
                if (p.Nom_du_produit) productsForLinking.push({ name: p.Nom_du_produit, slug: p.slug });
                
                // On ajoute le nom court s'il est différent
                if (p.nom_court && p.nom_court !== p.Nom_du_produit) {
                    productsForLinking.push({ name: p.nom_court, slug: p.slug });
                }
                
                // Cas particuliers pour faciliter la détection (mots clés fréquents)
                const lowerName = p.Nom_du_produit.toLowerCase();
                if (lowerName.includes('ski-mojo')) {
                    if (!productsForLinking.some(x => x.name === 'Ski-Mojo')) productsForLinking.push({ name: 'Ski-Mojo', slug: p.slug });
                    if (!productsForLinking.some(x => x.name === 'Ski Mojo')) productsForLinking.push({ name: 'Ski Mojo', slug: p.slug });
                }
                if (lowerName.includes('hypershell')) {
                    if (!productsForLinking.some(x => x.name === 'Hypershell')) productsForLinking.push({ name: 'Hypershell', slug: p.slug });
                }
                if (lowerName.includes('stoko')) {
                    if (!productsForLinking.some(x => x.name === 'Stoko')) productsForLinking.push({ name: 'Stoko', slug: p.slug });
                }
            });
        }
    }
} catch (error: any) {
    console.error(`Erreur article ${slug}:`, error);
    errorMessage = error.message;
}

if (!article && !errorMessage) {
    return Astro.redirect('/404');
}

// Application du linkify sur le contenu
const linkifiedContent = article?.contenu ? linkifyProducts(article.contenu, productsForLinking) : '';

const directusUrl = "https://spirited-squid.pikapod.net";
const imageUrl = article?.image_principale
    ? `${directusUrl}/assets/${article.image_principale}`
    : null;

const formatDate = (date: string) => {
    if (!date) return '';
    try {
        const d = new Date(date);
        if (isNaN(d.getTime())) return date;
        return new Intl.DateTimeFormat('fr-FR', { year:'numeric', month:'long', day:'numeric' }).format(d);
    } catch (e) {
        return date;
    }
};

---

<Layout
    title={article ? `${article.titre} | NeoSomaTech` : 'Article non trouvé'}
    description={article?.meta_description || article?.description_seo || 'Article sur les exosquelettes.'}
    image={imageUrl || '/favicon.png'}
    type="article"
    schemaItem={article}
>

    {errorMessage ? (
        <div class="container error-box">
            <strong>⚠️ Erreur :</strong> {errorMessage}
        </div>
    ) : article && (
        <article class="article-wrapper">
            <!-- HERO IMAGE -->
            {imageUrl && (
                <div class="article-hero">
                    <img src={imageUrl} alt={article.titre} />
                    <div class="article-hero-overlay"></div>
                </div>
            )}

            <div class="article-body container">
                <!-- BREADCRUMB -->
                <nav class="breadcrumb">
                    <a href="/">Accueil</a> /
                    <a href="/articles">Articles</a> /
                    <span>{article.titre}</span>
                </nav>

                <!-- META -->
                <div class="article-meta">
                    {article.date_publication && (
                        <time datetime={article.date_publication}>
                            📅 {formatDate(article.date_publication)}
                        </time>
                    )}
                    {article.auteur && <span>✍️ {article.auteur}</span>}
                </div>

                <!-- TITRE -->
                <h1>{article.titre}</h1>

                <!-- RÉSUMÉ SEO -->
                {article.description_seo && (
                    <p class="article-lead">{article.description_seo}</p>
                )}

                <!-- CONTENU HTML -->
                {linkifiedContent && (
                    <div class="article-content" set:html={linkifiedContent} />
                )}

                <!-- FOOTER ARTICLE -->
                <div class="article-footer">
                    <a href="/articles" class="btn btn-outline">&larr; Retour aux articles</a>
                </div>
            </div>
        </article>
    )}
</Layout>

<style>
    /* HERO IMAGE */
    .article-hero {
        position: relative;
        width: 100%;
        max-height: 480px;
        overflow: hidden;
    }
    .article-hero img {
        width: 100%;
        height: 480px;
        object-fit: cover;
    }
    .article-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 40%, var(--background) 100%);
    }

    @media (max-width: 768px) {
        .article-hero { max-height: 300px; }
        .article-hero img { height: 300px; }
    }

    /* CORPS DE L'ARTICLE */
    .article-body {
        max-width: 780px;
        padding-top: 2.5rem;
        padding-bottom: 5rem;
    }
    @media (max-width: 768px) {
        .article-body {
            padding-top: 1.5rem;
        }
    }
    .breadcrumb {
        font-size: 0.82rem;
        color: var(--text-light);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .breadcrumb a { color: #818cf8; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 300px;
    }
    .article-meta {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        font-size: 0.88rem;
        color: var(--text-light);
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }
    h1 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 900;
        color: #fff;
        line-height: 1.2;
        letter-spacing: -1px;
        margin-bottom: 1.5rem;
    }
    .article-lead {
        font-size: 1.15rem;
        color: #a5b4fc;
        line-height: 1.7;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
        font-style: italic;
    }

    /* CONTENU RICHE (WYSIWYG de Directus) */
    .article-content {
        color: var(--text);
        line-height: 1.85;
        font-size: 1.05rem;
        font-family: var(--font-description);
    }
    :global(.article-content *) {
        font-family: var(--font-description) !important;
    }
    .article-content h2 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #fff;
        margin: 2.5rem 0 1rem;
        letter-spacing: -0.5px;
    }
    .article-content h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #e2e8f0;
        margin: 2rem 0 0.75rem;
    }
    .article-content p { margin-bottom: 1.25rem; }
    .article-content strong { color: #e2e8f0; }
    .article-content a { color: #818cf8; text-decoration: underline; text-underline-offset: 3px; }
    .article-content a:hover { color: #a5b4fc; }

    /* Style pour les liens produits automatiques */
    :global(.article-content .product-inline-link) {
        color: #818cf8;
        text-decoration: none !important;
        border-bottom: 1px solid rgba(129, 140, 248, 0.4);
        font-weight: 600;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-block;
        line-height: 1.2;
        padding: 0 2px;
    }
    :global(.article-content .product-inline-link:hover) {
        color: #fff;
        background: rgba(99, 102, 241, 0.2);
        border-bottom-color: #6366f1;
        border-radius: 4px;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
    }

    .article-content ul, .article-content ol {
        margin: 1rem 0 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .article-content li::marker { color: #6366f1; }
    .article-content blockquote {
        border-left: 3px solid #6366f1;
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
        background: rgba(99,102,241,0.08);
        border-radius: 0 8px 8px 0;
        color: #a5b4fc;
        font-style: italic;
    }
    .article-content img {
        max-width: 100%;
        border-radius: 12px;
        margin: 1.5rem 0;
    }
    .article-content pre, .article-content code {
        background: var(--surface);
        border-radius: 6px;
        font-family: monospace;
    }
    .article-content pre { padding: 1rem; overflow-x: auto; }
    .article-content code { padding: 0.15rem 0.4rem; font-size: 0.9rem; }

    .article-footer {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }
    .error-box {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #fca5a5;
        padding: 2rem;
        border-radius: 12px;
        margin: 3rem auto;
        max-width: 600px;
        text-align: center;
    }
</style>
