---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | NeoSomaTech" description="Contactez l'équipe NeoSomaTech pour toute question sur nos exosquelettes.">
    <div class="page container">
        <div class="breadcrumb"><a href="/">Accueil</a> / Contact</div>
        <h1>Nous <span class="gradient-text">Contacter</span></h1>
        <p class="intro">Une question sur un produit, un conseil d'achat ou un partenariat ? Écrivez-nous, nous répondons sous 24h.</p>

        <div class="contact-grid">
            <div class="contact-info">
                <div class="info-block">
                    <span class="icon">📧</span>
                    <div>
                        <strong>Email</strong>
                        <p>neosomatech@gmail.com</p>
                    </div>
                </div>
                <div class="info-block">
                    <span class="icon">⏰</span>
                    <div>
                        <strong>Disponibilité</strong>
                        <p>7j/7, 24h/24</p>
                    </div>
                </div>
                <div class="info-block">
                    <span class="icon">🕒</span>
                    <div>
                        <strong>Délai de réponse</strong>
                        <p>Sous 72h maximum. Réponse envoyée à l'adresse indiquée dans le formulaire.</p>
                    </div>
                </div>
            </div>

            <form class="contact-form" id="contactForm">
                <div class="form-group">
                    <label for="name">Votre nom</label>
                    <input id="name" name="name" type="text" placeholder="Jean Dupont" required />
                </div>
                <div class="form-group">
                    <label for="email">Votre email</label>
                    <input id="email" name="email" type="email" placeholder="jean@exemple.com" required />
                </div>
                <div class="form-group">
                    <label for="tel">Votre numéro de téléphone (optionnel)</label>
                    <input id="tel" name="tel" type="tel" placeholder="06 12 34 56 78" />
                </div>
                <div class="form-group">
                    <label for="message">Votre message</label>
                    <textarea id="message" name="message" rows="5" placeholder="Décrivez votre demande..." required></textarea>
                </div>

                <button type="submit" class="btn" id="submitBtn">Envoyer le message &rarr;</button>
                <div id="statusMessage" class="status-message"></div>
            </form>
        </div>
    </div>
</Layout>

<script>
    const form = document.querySelector('#contactForm') as HTMLFormElement;
    const statusDiv = document.querySelector('#statusMessage') as HTMLDivElement;
    const submitBtn = document.querySelector('#submitBtn') as HTMLButtonElement;

    // Réinitialise le message d'état quand l'utilisateur tape à nouveau
    form?.querySelectorAll('input, textarea').forEach(input => {
        input.addEventListener('input', () => {
            statusDiv.style.display = 'none';
            statusDiv.className = 'status-message';
        });
    });

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Reset UI
        statusDiv.textContent = 'Chargement de votre message...';
        statusDiv.className = 'status-message info show';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.textContent = 'Envoi en cours...';

        const formData = new FormData(form);

        try {
            const response = await fetch('/api/contact', {
                method: 'POST',
                body: formData,
            });

            const result = await response.json().catch(() => ({ message: 'Erreur de lecture de la réponse serveur.' }));

            if (response.ok) {
                statusDiv.textContent = result.message || 'Message envoyé !';
                statusDiv.className = 'status-message success show';
                form.reset();
                submitBtn.textContent = 'Message Envoyé ✓';
                setTimeout(() => {
                    submitBtn.textContent = 'Envoyer un autre message →';
                    submitBtn.style.opacity = '1';
                    submitBtn.disabled = false;
                }, 3000);
            } else {
                // Log de l'erreur détaillée pour aider au débogage
                if (result.debug) console.error('Server Debug Info:', result.debug);
                
                statusDiv.textContent = result.message || 'Une erreur est survenue lors de l’envoi.';
                statusDiv.className = 'status-message error show';
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
                submitBtn.textContent = 'Réessayer l\'envoi →';
            }
        } catch (error: any) {
            console.error('Fetch error:', error);
            statusDiv.textContent = 'Erreur réseau ou crash du serveur. Consultez la console.';
            statusDiv.className = 'status-message error show';
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            submitBtn.textContent = 'Réessayer l\'envoi →';
        }
    });
</script>

<style>
    .page { max-width: 900px; padding: 4rem 1.5rem 6rem; }
    .breadcrumb { font-size: 0.83rem; color: var(--text-light); margin-bottom: 1.5rem; }
    .breadcrumb a { color: #818cf8; text-decoration: none; }
    h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: #fff; letter-spacing: -1.5px; margin-bottom: 0.75rem; }
    .gradient-text {
        background: linear-gradient(135deg, #6366f1, #8b5cf6, #ec4899);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .intro { color: var(--text-light); margin-bottom: 3rem; font-size: 1.05rem; }
    .contact-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; }
    .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
    .info-block { display: flex; align-items: flex-start; gap: 1rem; }
    .icon { font-size: 1.5rem; }
    .info-block strong { color: #fff; display: block; margin-bottom: 0.25rem; }
    .info-block p { color: var(--text-light); font-size: 0.9rem; }
    .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-group label { font-size: 0.88rem; font-weight: 500; color: #a5b4fc; }
    .form-group input, .form-group textarea {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-family: inherit;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        transition: border-color 0.2s;
        outline: none;
        resize: vertical;
    }
    .form-group input:focus, .form-group textarea:focus { border-color: var(--primary); }
    .form-group input::placeholder, .form-group textarea::placeholder { color: #4a5568; }
    
    /* STATUS MESSAGES */
    .status-message {
        margin-top: 1.5rem;
        padding: 1.25rem;
        border-radius: 12px;
        font-size: 0.95rem;
        display: none;
        animation: fadeIn 0.3s ease-out;
        line-height: 1.5;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .status-message.show {
        display: block;
    }
    .status-message.success {
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        box-shadow: 0 4px 20px rgba(16, 185, 129, 0.1);
    }
    .status-message.error {
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        box-shadow: 0 4px 20px rgba(239, 68, 68, 0.1);
    }
    .status-message.info {
        background: rgba(59, 130, 246, 0.08);
        border: 1px solid rgba(59, 130, 246, 0.2);
        color: #60a5fa;
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
    }

    .info-block {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        padding: 1.25rem;
        border-radius: 16px;
        transition: transform 0.2s, border-color 0.2s;
    }
    .info-block:hover {
        transform: translateX(5px);
        border-color: var(--primary);
    }
    .info-block p {
        line-height: 1.4;
    }

    @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; } }
</style>