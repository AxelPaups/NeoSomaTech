---
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus, directusUrl } from '../../lib/directus';
import {
	PRODUCT_FIELDS,
	getCustomAlts,
	collectGallery,
	collectVariantGallery,
	parsePromo,
	renderPriceHtml,
	SPEC_DEFS,
} from '../../lib/productPage';
import SpecIcon from '../../components/product/SpecIcon.astro';
import ProductPrice from '../../components/product/ProductPrice.astro';
import '../../styles/product-page.css';

const { slug } = Astro.params;

let produit: Record<string, unknown> | null = null;
let produitsSimilaires: Record<string, unknown>[] = [];
let avis: Record<string, unknown>[] = [];
let articlesLies: Record<string, unknown>[] = [];
let errorMessage: string | null = null;

try {
	const data = await fetchDirectus(
		`/items/Produits?filter[slug][_eq]=${slug}&fields=${PRODUCT_FIELDS}&limit=1`,
	);
	produit = (Array.isArray(data) ? data[0] : data) as Record<string, unknown> | null;

	if (produit) {
		const brandFilter = produit.marque ? `&filter[marque][_eq]=${produit.marque}` : '';
		const others = await fetchDirectus(
			`/items/Produits?filter[slug][_neq]=${slug}${brandFilter}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=4`,
		);
		produitsSimilaires = Array.isArray(others) ? others : [];

		if (produitsSimilaires.length < 4) {
			const excludeSlugs = [slug, ...produitsSimilaires.map((p) => p.slug || p.id)];
			const more = await fetchDirectus(
				`/items/Produits?filter[slug][_nin]=${excludeSlugs.join(',')}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=${4 - produitsSimilaires.length}`,
			);
			if (Array.isArray(more)) produitsSimilaires = [...produitsSimilaires, ...more];
		}

		try {
			const avisData = await fetchDirectus(
				`/items/Avis?filter[produit_slug][_eq]=${slug}&fields=prenom,note,avis_texte,date_created&limit=50`,
			);
			avis = Array.isArray(avisData) ? avisData : [];
		} catch {
			avis = [];
		}

		// Articles liés : cherche par nom du produit ou marque dans le contenu
		try {
			const nomProduit = (produit.Nom_du_produit as string) || '';
			const marque = (produit.marque as string) || '';
			const searchTerm = encodeURIComponent(marque || nomProduit);
			const articlesData = await fetchDirectus(
				`/items/Articles?filter[contenu][_contains]=${searchTerm}&fields=titre,slug,description_seo,image_principale,date_publication&limit=3`,
			);
			articlesLies = Array.isArray(articlesData) ? articlesData : [];
		} catch {
			articlesLies = [];
		}
	}
} catch (error: unknown) {
	errorMessage = error instanceof Error ? error.message : 'Erreur inconnue';
}

const noteMoyenne =
	avis.length > 0
		? Math.round((avis.reduce((sum, a) => sum + (Number(a.note) || 0), 0) / avis.length) * 10) / 10
		: null;

if (!produit && !errorMessage) {
	return Astro.redirect('/404');
}

const customAlts = getCustomAlts(produit?.custom_alts as string | undefined);
let allImages = collectGallery(produit?.image as string | undefined, produit?.galerie, directusUrl);
let imageUrl = allImages[0] || null;
const { isPromoValid } = parsePromo(
	Boolean(produit?.promo),
	produit?.prix_promo as string | undefined,
);
const productName = (produit?.Nom_du_produit as string) || 'Produit';
const specValueByKey: Record<string, string> = {};
for (const def of SPEC_DEFS) {
	const raw = produit ? (produit as any)?.[def.field] : null;
	const s = raw == null ? '' : String(raw).trim();
	specValueByKey[def.key] = s;
}
const hasAnySpecsInProduit = Object.values(specValueByKey).some(Boolean);
const hasVariants = produit?.variantes && Array.isArray(produit.variantes) && produit.variantes.length > 0;

type VariantButtonData = {
	label: string;
	name: string;
	price: string;
	promo: string;
	prixPromo: string;
	image: string | null;
	url: string;
	attente: string;
	descShort: string;
	descLong: string;
	gallery: string;
	specs: string;
	modele: string;
	taille: string;
};

const variantItems: VariantButtonData[] = hasVariants && produit
	? (produit.variantes as Record<string, unknown>[]).map((v) => {
			const variantGallery = collectVariantGallery(v, allImages, directusUrl);
			const vPromo = parsePromo(Boolean(v.promo), v.prix_promo as string);
			const specPayload: Record<string, string> = {};
			for (const def of SPEC_DEFS) {
				const raw = (v as any)?.[def.field];
				specPayload[def.key] = raw == null ? '' : String(raw).trim();
			}
			return {
				label: String(v.nom_court || v.Nom_du_produit || ''),
				name: (v.Nom_du_produit as string) || productName,
				price: String(v.prix || produit.prix || ''),
				promo: vPromo.isPromoValid ? 'true' : 'false',
				prixPromo: String(v.prix_promo || ''),
				image: v.Image ? `${directusUrl}/assets/${v.Image}` : imageUrl,
				url: String(v.bouton_acheter || v.Lien_achat || produit.Bouton_acheter || ''),
				attente: String(v.texte_attente_sortie || produit.texte_attente_sortie || ''),
				descShort: String(v.description_simple || produit.descripton_simple || ''),
				descLong: String(v.description_principale || produit.description_principale || ''),
				gallery: JSON.stringify(variantGallery),
				specs: JSON.stringify(specPayload),
				modele: v.modele != null ? String(v.modele) : '',
				taille: v.taille != null ? String(v.taille) : '',
			};
		})
	: [];

// Produit sans visuel propre : on retombe sur la galerie de la première variante illustrée
if (allImages.length === 0) {
	const firstVariantWithGallery = variantItems.find((v) => {
		try {
			return (JSON.parse(v.gallery) as string[]).length > 0;
		} catch {
			return false;
		}
	});
	if (firstVariantWithGallery) {
		allImages = JSON.parse(firstVariantWithGallery.gallery) as string[];
		imageUrl = allImages[0] || null;
	}
}

// CAS 1 (modele + taille) vs CAS 2 (sélecteur classique) — détecté sur la première variante
const hasModeleTaille =
	hasVariants &&
	Array.isArray(produit?.variantes) &&
	(produit!.variantes as Record<string, unknown>[])[0]?.modele != null;

const modeleOptions: string[] = hasModeleTaille
	? [...new Set(variantItems.map((v) => v.modele).filter(Boolean))]
	: [];

const hasAnySpecsInVariants = variantItems.some((v) => {
	try {
		const payload = JSON.parse(v.specs) as Record<string, string>;
		return Object.values(payload).some(Boolean);
	} catch {
		return false;
	}
});

const hasAnySpecs = hasAnySpecsInProduit || hasAnySpecsInVariants;

const faqItems: { question: string; reponse: string }[] =
	produit?.faqs && Array.isArray(produit.faqs)
		? (produit.faqs as Record<string, unknown>[]).map((f) => ({
				question: String(f.question ?? ''),
				reponse: String(f.reponse ?? ''),
			}))
		: [];

const metaDescription =
	(produit?.seo_description as string) ||
	(produit?.descripton_simple as string) ||
	'Exosquelette NeoSomaTech';
const titleWords = productName.split(/\s+/);
const marqueeText = `${productName} — `.repeat(4);
const heroPriceHtml = renderPriceHtml(
	String(produit?.prix ?? ''),
	isPromoValid,
	String(produit?.prix_promo ?? ''),
);
---

<Layout
	title={produit ? `${productName} | NeoSomaTech` : 'Produit introuvable'}
	description={metaDescription}
	image={imageUrl || '/og-image.png'}
	type="product"
	schemaItem={{ ...produit, allImages }}
	faqs={produit?.faqs}
	aggregateRating={noteMoyenne && avis.length > 0 ? { ratingValue: noteMoyenne, reviewCount: avis.length } : undefined}
>
	<div class="product-page" data-product-page>
		<div class="pp-ambient" aria-hidden="true">
			<div class="pp-orb pp-orb-1"></div>
			<div class="pp-orb pp-orb-2"></div>
			<div class="pp-orb pp-orb-3"></div>
			<div class="pp-grain"></div>
		</div>

		<div class="pp-inner">
			{errorMessage ? (
				<div class="pp-error">⚠️ {errorMessage}</div>
			) : (
				produit && (
					<>
						<nav class="pp-crumb" aria-label="Fil d'Ariane">
							<a href="/">Accueil</a>
							<span class="pp-crumb-sep">/</span>
							<a href="/boutique">Boutique</a>
							<span class="pp-crumb-sep">/</span>
							<span id="pp-crumb-name">{productName}</span>
						</nav>

						<header class="pp-hero-band">
							<div class="pp-hero-left">
								{produit.marque && (
									<div class="pp-marque">
										<span class="pp-marque-dot"></span>
										{produit.marque as string}
									</div>
								)}
								<h1 class="pp-title" id="pp-product-title">
									<span class="pp-title-line">
										{titleWords.map((word, i) => (
											<span class="pp-title-word" style={`animation-delay: ${0.35 + i * 0.06}s`}>
												{word}{' '}
											</span>
										))}
									</span>
								</h1>
								{produit.descripton_simple && (
									<p class="pp-short-desc">{produit.descripton_simple as string}</p>
								)}
								{noteMoyenne && (
									<div class="pp-rating-pill">
										<strong>{noteMoyenne}</strong>
										<div class="pp-rating-stars">
											{[1, 2, 3, 4, 5].map((i) => (
												<span class={i <= Math.round(noteMoyenne) ? 'star filled' : 'star'}>★</span>
											))}
										</div>
										<span>({avis.length} avis)</span>
									</div>
								)}
							</div>
							<div class="pp-hero-price">
								<div class="pp-price-card" id="price-block-container">
									<div class="pp-price-label">Prix TTC</div>
									<Fragment set:html={heroPriceHtml} />
								</div>
							</div>
						</header>

						<section class="pp-stage" id="pp-stage">
							<div class="pp-gallery-wrap">
								{allImages.length > 0 ? (
									<div class="carousel-container">
										<div class="pp-gallery-frame">
											<div class="pp-gallery-inner">
												<img
													id="main-carousel-img"
													class="pp-gallery-img"
													src={allImages[0]}
													alt={customAlts[0] || `${productName} — vue 1`}
													width="900"
													height="900"
													fetchpriority="high"
													loading="eager"
												/>
												<div
													class="pp-gallery-controls carousel-controls"
													style={allImages.length <= 1 ? 'display:none' : undefined}
												>
													<button type="button" id="prev-btn" aria-label="Image précédente">←</button>
													<button type="button" id="next-btn" aria-label="Image suivante">→</button>
												</div>
												<div class="pp-gallery-counter">
													<span id="gallery-counter-current">01</span> / <span id="gallery-counter-total">{String(allImages.length).padStart(2, '0')}</span>
												</div>
											</div>
										</div>
										<div
											class="pp-thumbs carousel-thumbnails"
											style={allImages.length <= 1 ? 'display:none' : undefined}
										>
											{allImages.map((imgUrl, index) => (
												<button
													type="button"
													class={`pp-thumb-btn thumbnail-btn ${index === 0 ? 'active' : ''}`}
													data-index={index}
													data-image={imgUrl}
													aria-label={`Image ${index + 1}`}
												>
													<img
														src={imgUrl}
														alt={customAlts[index] || `${productName} — vue ${index + 1}`}
														width="72"
														height="72"
														loading="lazy"
													/>
												</button>
											))}
										</div>
									</div>
								) : (
									<div class="pp-gallery-placeholder">
										<span>🦾</span>
										<p>Visuel à venir</p>
									</div>
								)}
							</div>

							<aside class="pp-panel">
								<p class="pp-panel-title">Configuration</p>

								<div class="pp-panel-price" id="panel-price-block">
									<ProductPrice
										prix={produit.prix as string}
										isPromo={isPromoValid}
										promoPrice={produit.prix_promo as string}
									/>
								</div>

								{hasVariants && hasModeleTaille && (
									<div class="variants-selection" data-variants-mode="modele-taille">
										<div class="pp-variants-selectors">
											<label class="pp-variants-field">
												<span class="pp-variants-label">Modèle</span>
												<select id="pp-modele-select" class="pp-variants-select">
													{modeleOptions.map((m) => (
														<option value={m}>{m}</option>
													))}
												</select>
											</label>
											<label class="pp-variants-field">
												<span class="pp-variants-label">Taille</span>
												<select id="pp-taille-select" class="pp-variants-select"></select>
											</label>
										</div>
										<div class="pp-variants-grid" hidden>
											{variantItems.map((v, i) => (
												<button
													type="button"
													class={`variant-btn ${i === 0 ? 'active' : ''}`}
													data-name={v.name}
													data-price={v.price}
													data-promo={v.promo}
													data-prix-promo={v.prixPromo}
													data-image={v.image}
													data-url={v.url}
													data-attente={v.attente}
													data-desc-short={v.descShort}
													data-desc-long={v.descLong}
													data-gallery={v.gallery}
													data-specs={v.specs}
													data-modele={v.modele}
													data-taille={v.taille}
												>
													<span>{v.label}</span>
												</button>
											))}
										</div>
									</div>
								)}

								{hasVariants && !hasModeleTaille && (
									<div class="variants-selection" data-variants-mode="simple">
										<span class="pp-variants-label">Modèle</span>
										<div class="pp-variants-grid">
											<button
												type="button"
												class="variant-btn active"
												data-name={productName}
												data-price={produit.prix || ''}
												data-promo={isPromoValid ? 'true' : 'false'}
												data-prix-promo={produit.prix_promo || ''}
												data-image={imageUrl}
												data-url={produit.Bouton_acheter || ''}
												data-attente={produit.texte_attente_sortie || ''}
												data-desc-short={produit.descripton_simple || ''}
												data-desc-long={produit.description_principale || ''}
												data-gallery={JSON.stringify(allImages)}
												data-specs={JSON.stringify(specValueByKey)}
											>
												<span>{produit.nom_court || 'Modèle principal'}</span>
												<span class="variant-btn-check" aria-hidden="true"></span>
											</button>
											{variantItems.map((v) => (
												<button
													type="button"
													class="variant-btn"
													data-name={v.name}
													data-price={v.price}
													data-promo={v.promo}
													data-prix-promo={v.prixPromo}
													data-image={v.image}
													data-url={v.url}
													data-attente={v.attente}
													data-desc-short={v.descShort}
													data-desc-long={v.descLong}
													data-gallery={v.gallery}
													data-specs={v.specs}
												>
													<span>{v.label}</span>
													<span class="variant-btn-check" aria-hidden="true"></span>
												</button>
											))}
										</div>
									</div>
								)}

								<div class="pp-trust-row">
									<span class="pp-trust-badge">✓ Sélection expert</span>
									<span class="pp-trust-badge">✓ Conseil NeoSoma</span>
									{produit.garantie && <span class="pp-trust-badge">🛡 {produit.garantie as string}</span>}
								</div>

								<div class="pp-cta-stack">
									{produit.prix ? (
										<a
											href={(produit.Bouton_acheter as string) || '#'}
											class="btn btn-buy"
											id="main-cta-btn"
											target={produit.Bouton_acheter ? '_blank' : '_self'}
											rel={produit.Bouton_acheter ? 'noopener noreferrer' : undefined}
										>
											Acheter maintenant
										</a>
									) : (
										<button
											type="button"
											class="btn btn-buy btn-disabled tooltip-btn"
											id="main-cta-btn"
											data-tooltip={(produit.texte_attente_sortie as string) || 'Bientôt disponible'}
										>
											Me notifier à la sortie
										</button>
									)}
									<a href="/boutique" class="btn btn-outline">← Retour boutique</a>
									{hasAnySpecs && (
										<a href="/comparateur" class="pp-comparateur-link">
											Comparer avec d'autres modèles →
										</a>
									)}
								</div>
							</aside>
						</section>

						{hasAnySpecs && (
							<section class="pp-specs-section reveal">
								<p class="pp-section-eyebrow">Fiche technique</p>
								<h2 class="pp-section-heading">Caractéristiques clés</h2>
								<div class="pp-specs-bento">
									{SPEC_DEFS.map((def, i) => (
										<article
											class={`pp-spec-card reveal ${specValueByKey[def.key] ? '' : 'is-hidden'}`}
											data-spec-key={def.key}
											style={`transition-delay: ${i * 0.07}s`}
										>
											<div class="pp-spec-icon-wrap">
												<SpecIcon icon={def.icon} />
											</div>
											<p class="pp-spec-label">{def.label}</p>
											<p class="pp-spec-value">{specValueByKey[def.key]}</p>
										</article>
									))}
								</div>
							</section>
						)}

						<div class="pp-marquee-wrap" aria-hidden="true">
							<div class="pp-marquee-track" id="pp-marquee-track">
								<span class="pp-marquee-text">{marqueeText}</span>
								<span class="pp-marquee-text">{marqueeText}</span>
							</div>
						</div>

						<div class="pp-content">
							{produit.description_principale && (
								<section class="pp-block pp-block--description reveal" id="description">
									<div class="pp-block-header">
										<span class="pp-block-num">01</span>
										<h2 class="pp-block-title">Analyse complète</h2>
									</div>
									<header class="pp-description-header">
										<p class="pp-description-kicker">Dossier produit</p>
										<p class="pp-description-product">{productName}</p>
										<div class="pp-description-chips">
											{produit.marque && <span class="pp-chip">Marque: {produit.marque as string}</span>}
											{produit.poids && <span class="pp-chip">Poids: {String(produit.poids)}</span>}
											{produit.autonomie && <span class="pp-chip">Autonomie: {String(produit.autonomie)}</span>}
											{produit.garantie && <span class="pp-chip">Garantie: {String(produit.garantie)}</span>}
										</div>
									</header>
									<div class="pp-description-body">
										<div class="pp-rich rich-content" set:html={produit.description_principale as string} />
									</div>
								</section>
							)}

							<section class="pp-block reveal" id="faq">
								<div class="pp-block-header">
									<span class="pp-block-num">02</span>
									<h2 class="pp-block-title">Questions fréquentes</h2>
								</div>
								{faqItems.length > 0 ? (
									<div class="pp-faq-list faq-accordion">
										{faqItems.map((f) => (
											<details class="pp-faq-item faq-item">
												<summary class="pp-faq-q faq-question">
													<span>{f.question}</span>
													<span class="pp-faq-icon" aria-hidden="true">+</span>
												</summary>
												<div class="pp-faq-a faq-answer">
													<div class="pp-rich" set:html={f.reponse} />
												</div>
											</details>
										))}
									</div>
								) : (
									<p style="color: var(--text-light); line-height: 1.7;">
										FAQ en préparation. <a href="/contact" style="color: #818cf8">Contactez-nous →</a>
									</p>
								)}
							</section>

							<section class="pp-block reveal" id="avis-section">
								<div class="pp-block-header">
									<span class="pp-block-num">03</span>
									<h2 class="pp-block-title">Avis clients</h2>
								</div>

								<div class="pp-avis-layout">
									{noteMoyenne ? (
										<div class="pp-avis-score-ring">
											<div class="pp-avis-big-num">{noteMoyenne}</div>
											<div class="pp-rating-stars" style="justify-content:center; margin: 0.5rem 0;">
												{[1, 2, 3, 4, 5].map((i) => (
													<span class={i <= Math.round(noteMoyenne) ? 'star filled' : 'star'}>★</span>
												))}
											</div>
											<p style="font-size: 0.85rem; color: var(--text-light);">{avis.length} avis</p>
										</div>
									) : (
										<div class="pp-avis-score-ring">
											<p style="color: var(--text-light);">Soyez le premier à noter ce produit</p>
										</div>
									)}

									<div class="pp-avis-list">
										{avis.length > 0 ? (
											avis.map((a) => (
												<article class="pp-avis-card avis-card">
													<div class="pp-avis-card-top">
														<div class="pp-avis-avatar">
															{a.prenom ? String(a.prenom)[0].toUpperCase() : '?'}
														</div>
														<div>
															<strong style="color:#fff">{a.prenom || 'Anonyme'}</strong>
															<div class="pp-rating-stars">
																{[1, 2, 3, 4, 5].map((i) => (
																	<span class={i <= (Number(a.note) || 0) ? 'star filled' : 'star'}>★</span>
																))}
															</div>
														</div>
													</div>
													<p style="color: var(--text-light); line-height: 1.7; margin: 0;">{String(a.avis_texte ?? '')}</p>
												</article>
											))
										) : (
											<p style="color: var(--text-light);">Aucun avis pour l'instant.</p>
										)}
									</div>
								</div>

								<div class="pp-avis-form-wrap avis-form-container">
									<h3 style="font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 1.25rem;">Laisser un avis</h3>
									<form id="avis-form" novalidate>
										<input type="hidden" name="produit_slug" value={slug} />
										<div class="form-group">
											<label class="form-label">Note <span class="required">*</span></label>
											<div class="stars-input" id="stars-input" role="group" aria-label="Note">
												{[1, 2, 3, 4, 5].map((i) => (
													<button type="button" class="star-btn" data-value={i} aria-label={`${i} étoiles`}>★</button>
												))}
											</div>
											<input type="hidden" name="note" id="note-value" value="" />
											<span class="field-error" id="note-error"></span>
										</div>
										<div class="form-row">
											<div class="form-group">
												<label for="avis-prenom" class="form-label">Prénom <span class="required">*</span></label>
												<input type="text" id="avis-prenom" name="prenom" class="form-input" autocomplete="given-name" />
												<span class="field-error" id="prenom-error"></span>
											</div>
											<div class="form-group">
												<label for="avis-email" class="form-label">Email <span class="required">*</span></label>
												<input type="email" id="avis-email" name="email" class="form-input" autocomplete="email" />
												<span class="field-error" id="email-error"></span>
											</div>
										</div>
										<div class="form-group">
											<label for="avis-tel" class="form-label">Téléphone <span style="color:var(--text-light);font-weight:400">(facultatif)</span></label>
											<input type="tel" id="avis-tel" name="telephone" class="form-input" autocomplete="tel" />
										</div>
										<div class="form-group">
											<label for="avis-texte" class="form-label">Commentaire <span class="required">*</span></label>
											<textarea id="avis-texte" name="avis_texte" class="form-input" rows={4}></textarea>
											<span class="field-error" id="avis-texte-error"></span>
										</div>
										<div style="display:flex; flex-wrap:wrap; gap:1rem; align-items:center; justify-content:space-between;">
											<span style="font-size:0.8rem;color:var(--text-light)"><span class="required">*</span> Obligatoire</span>
											<button type="submit" class="btn btn-buy" id="avis-submit">Envoyer mon avis</button>
										</div>
										<div id="avis-success" class="avis-success" style="display:none">✅ Merci ! Votre avis a été enregistré.</div>
										<div id="avis-error-global" class="avis-error-global" style="display:none"></div>
									</form>
								</div>
							</section>

							{articlesLies.length > 0 && (
								<section class="pp-block reveal">
									<div class="pp-block-header">
										<span class="pp-block-num">04</span>
										<h2 class="pp-block-title">Articles sur ce produit</h2>
									</div>
									<div class="pp-similar-scroll">
										{articlesLies.map((a) => (
											<article class="pp-similar-card">
												<a href={`/articles/${a.slug}`} class="pp-similar-img">
													{a.image_principale ? (
														<img src={`${directusUrl}/assets/${a.image_principale}`} alt={a.titre as string} loading="lazy" width="280" height="280" />
													) : (
														<span style="font-size:3rem;display:flex;align-items:center;justify-content:center;height:100%">📝</span>
													)}
												</a>
												<div class="pp-similar-body">
													<h3><a href={`/articles/${a.slug}`}>{a.titre as string}</a></h3>
													{a.description_seo && <p class="pp-similar-price" style="font-size:0.85rem;color:var(--text-light);font-weight:400">{a.description_seo as string}</p>}
													<a href={`/articles/${a.slug}`} class="pp-comparateur-link">Lire l'article →</a>
												</div>
											</article>
										))}
									</div>
								</section>
							)}

							{produitsSimilaires.length > 0 && (
								<section class="pp-block reveal">
									<div class="pp-block-header">
										<span class="pp-block-num">{articlesLies.length > 0 ? '05' : '04'}</span>
										<h2 class="pp-block-title">Vous aimerez aussi</h2>
									</div>
									<div class="pp-similar-scroll">
										{produitsSimilaires.map((p) => (
											<article class="pp-similar-card">
												<a href={`/produits/${p.slug || p.id}`} class="pp-similar-img">
													{p.image ? (
														<img src={`${directusUrl}/assets/${p.image}`} alt={p.Nom_du_produit as string} loading="lazy" />
													) : (
														<span style="font-size:3rem;display:flex;align-items:center;justify-content:center;height:100%">🦾</span>
													)}
												</a>
												<div class="pp-similar-body">
													{p.marque && <span class="pp-similar-brand">{p.marque as string}</span>}
													<h3><a href={`/produits/${p.slug || p.id}`}>{p.Nom_du_produit as string}</a></h3>
													<p class="pp-similar-price">{p.prix ? `${p.prix} €` : 'Contact'}</p>
													<a href={`/produits/${p.slug || p.id}`} class="pp-comparateur-link">Découvrir →</a>
												</div>
											</article>
										))}
									</div>
								</section>
							)}
						</div>

						<div class="pp-sticky-dock" id="pp-sticky-dock">
							<div class="pp-sticky-inner">
								<span class="pp-sticky-name" id="sticky-product-name">{productName}</span>
								<div class="pp-sticky-price" id="sticky-price-block">
									<Fragment set:html={heroPriceHtml} />
								</div>
								<div class="pp-sticky-cta">
									{produit.prix ? (
										<a
											href={(produit.Bouton_acheter as string) || '#'}
											class="btn"
											id="sticky-cta-btn"
											target="_blank"
											rel="noopener noreferrer"
										>
											Acheter
										</a>
									) : (
										<button type="button" class="btn btn-disabled" id="sticky-cta-btn" disabled>Bientôt</button>
									)}
								</div>
							</div>
						</div>
					</>
				)
			)}
		</div>
	</div>
</Layout>

<script src="../../scripts/product-page.client.ts"></script>
