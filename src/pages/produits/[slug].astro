---
// page : /produits/[slug]
// Layout e-commerce standard : image gauche / infos droite + description + FAQ + avis
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus } from '../../lib/directus';

const { slug } = Astro.params;
const directusUrl = "https://spirited-squid.pikapod.net";

let produit: any = null;
let produitsSimilaires: any[] = [];
let errorMessage: string | null = null;

try {
    // On ajoute galerie.* pour récupérer les relations Directus
    const data = await fetchDirectus(
        `/items/Produits?filter[slug][_eq]=${slug}&fields=id,Nom_du_produit,nom_court,prix,descripton_simple,description_principale,Bouton_acheter,image,slug,galerie.*,marque,variantes.*,variantes.galerie.*,promo,prix_promo&limit=1`
    );
    produit = Array.isArray(data) ? data[0] : data;

    // Récupération des produits similaires (priorité à la même marque si elle existe)
    if (produit) {
        // Tentative de récupération des produits de la même marque (excluant le produit actuel)
        // Note: 'marque' est récupéré même s'il n'est pas encore défini (renverra null)
        const brandFilter = produit.marque ? `&filter[marque][_eq]=${produit.marque}` : '';
        const others = await fetchDirectus(
            `/items/Produits?filter[slug][_neq]=${slug}${brandFilter}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=4`
        );
        produitsSimilaires = Array.isArray(others) ? others : [];

        // Si on n'a pas 4 produits de la même marque, on complète avec les autres produits du catalogue
        if (produitsSimilaires.length < 4) {
            const excludeSlugs = [slug, ...produitsSimilaires.map(p => p.slug || p.id)];
            // On utilise slug au lieu d'ID pour simplifier le filtrage _nin
            const fallbackQuery = `/items/Produits?filter[slug][_nin]=${excludeSlugs.join(',')}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=${4 - produitsSimilaires.length}`;
            const more = await fetchDirectus(fallbackQuery);
            if (Array.isArray(more)) {
                produitsSimilaires = [...produitsSimilaires, ...more];
            }
        }
    }
} catch (error: any) {
    console.error(`Erreur produit ${slug}:`, error);
    errorMessage = error.message;
}

if (!produit && !errorMessage) {
    return Astro.redirect('/404');
}

// Extraction de l'image principale
const imageUrl = produit?.image
    ? `${directusUrl}/assets/${produit.image}`
    : null;

// Extraction des images de la galerie
let allImages: string[] = [];
if (imageUrl) allImages.push(imageUrl);

if (produit?.galerie && Array.isArray(produit.galerie)) {
    produit.galerie.forEach((item: any) => {
        // La clé dépend de votre config sur Directus. M2M par défaut c'est directus_files_id
        const fileId = item.directus_files_id || item.image || (typeof item === 'string' ? item : null);
        if (fileId) {
            allImages.push(`${directusUrl}/assets/${fileId}`);
        }
    });
}

const jsonLd = produit ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": produit.Nom_du_produit,
    "description": produit.descripton_simple,
    "image": imageUrl,
    "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "price": produit.prix || "0",
        "availability": "https://schema.org/InStock",
        "url": produit.Bouton_acheter || Astro.url.href
    }
}) : null;

let isPromoValid = false;
let displayPromoPrice = '';

if (produit && produit.promo && produit.prix_promo) {
    const rawPromo = String(produit.prix_promo).replace(',', '.').replace(/[^\d.-]/g, '');
    const promoNum = parseFloat(rawPromo);
    
    if (!isNaN(promoNum)) {
        isPromoValid = true;
        displayPromoPrice = `${promoNum.toFixed(2).replace('.00', '')} €`;
    } else {
        isPromoValid = true;
        displayPromoPrice = String(produit.prix_promo).includes('€') ? produit.prix_promo : `${produit.prix_promo} €`;
    }
}
---

<Layout
    title={produit ? `${produit.Nom_du_produit} | NeoSomaTech` : 'Produit introuvable'}
    description={produit?.descripton_simple || 'Exosquelette NeoSomaTech'}
    image={imageUrl || '/favicon.png'}
>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    <div class="page-wrapper container">

        {errorMessage ? (
            <div class="error-box">⚠️ {errorMessage}</div>
        ) : produit && (
            <>
                <!-- BREADCRUMB -->
                <nav class="breadcrumb">
                    <a href="/">Accueil</a>
                    <span class="sep">/</span>
                    <a href="/boutique">Boutique</a>
                    <span class="sep">/</span>
                    <span>{produit.Nom_du_produit}</span>
                </nav>

                <!-- ===== BLOC PRINCIPAL (image gauche / infos droite) ===== -->
                <section class="product-top">
                    <!-- IMAGE GAUCHE (CARROUSEL) -->
                    <div class="product-gallery">
                        {allImages.length > 0 ? (
                            <div class="carousel-container">
                                <div class="carousel-main">
                                    <img id="main-carousel-img" src={allImages[0]} alt={produit.Nom_du_produit} />
                                    
                                    {allImages.length > 1 && (
                                        <div class="carousel-controls">
                                            <button id="prev-btn" aria-label="Image précédente">&larr;</button>
                                            <button id="next-btn" aria-label="Image suivante">&rarr;</button>
                                        </div>
                                    )}
                                </div>
                                {allImages.length > 1 && (
                                    <div class="carousel-thumbnails">
                                        {allImages.map((imgUrl, index) => (
                                            <button 
                                                class={`thumbnail-btn ${index === 0 ? 'active' : ''}`} 
                                                data-index={index}
                                                data-image={imgUrl}
                                                aria-label={`Voir l'image ${index + 1}`}
                                            >
                                                <img src={imgUrl} alt={`${produit.Nom_du_produit} - vue ${index + 1}`} />
                                            </button>
                                        ))}
                                    </div>
                                )}
                            </div>
                        ) : (
                            <div class="image-placeholder">
                                <span>🦾</span>
                                <p>Image à venir</p>
                            </div>
                        )}
                    </div>

                    <!-- INFOS DROITE -->
                    <div class="product-details">
                        <div class="product-tag">Exosquelette</div>
                        <h1>{produit.Nom_du_produit}</h1>

                        <!-- PRIX -->
                        <div class="price-block" id="price-block-container">
                            {isPromoValid ? (
                                <>
                                    <span class="price original-price">
                                        {produit.prix ? `${produit.prix} €` : ''}
                                    </span>
                                    <span class="price promo-price">
                                        {displayPromoPrice}
                                    </span>
                                </>
                            ) : (
                                <span class="price">
                                    {produit.prix ? `${produit.prix} €` : 'Nous contacter'}
                                </span>
                            )}
                            {produit.prix && <span class="price-note">TTC · Livraison incluse</span>}
                        </div>

                        <!-- DESCRIPTION COURTE -->
                        {produit.descripton_simple && (
                            <p class="short-desc">{produit.descripton_simple}</p>
                        )}

                        <!-- VARIANTES -->
                        {produit.variantes && produit.variantes.length > 0 && (
                            <div class="variants-selection">
                                <span class="variants-label">Choisir un modèle :</span>
                                <div class="variants-grid">
                                    <button 
                                        class="variant-btn active" 
                                        data-name="Standard"
                                        data-price={produit.prix || ''}
                                        data-promo={isPromoValid ? 'true' : 'false'}
                                        data-prix-promo={produit.prix_promo || ''}
                                        data-image={imageUrl}
                                        data-url={produit.Bouton_acheter || ''}
                                        data-desc-short={produit.descripton_simple || ''}
                                        data-desc-long={produit.description_principale || ''}
                                        data-gallery={JSON.stringify(allImages)}
                                    >
                                        {produit.nom_court || 'Par défaut'}
                                    </button>
                                    {produit.variantes.map((v: any) => {
                                        // Collecte des images de la galerie de la variante
                                        let variantGallery: string[] = [];
                                        if (v.Image) variantGallery.push(`${directusUrl}/assets/${v.Image}`);
                                        if (v.galerie && Array.isArray(v.galerie)) {
                                            v.galerie.forEach((item: any) => {
                                                const fileId = item.directus_files_id || item.image || (typeof item === 'string' ? item : null);
                                                if (fileId) variantGallery.push(`${directusUrl}/assets/${fileId}`);
                                            });
                                        }

                                        return (
                                            <button 
                                                class="variant-btn" 
                                                data-name={v.nom_court || v.Nom_du_produit}
                                                data-price={v.prix || produit.prix || ''}
                                                data-promo={v.promo !== undefined && v.promo !== null ? (v.promo ? 'true' : 'false') : (produit.promo ? 'true' : 'false')}
                                                data-prix-promo={v.prix_promo !== undefined && v.prix_promo !== null ? v.prix_promo : (produit.prix_promo || '')}
                                                data-image={v.Image ? `${directusUrl}/assets/${v.Image}` : imageUrl}
                                                data-url={v.bouton_acheter || v.Lien_achat || produit.Bouton_acheter || ''}
                                                data-desc-short={v.description_simple || produit.descripton_simple || ''}
                                                data-desc-long={v.description_principale || produit.description_principale || ''}
                                                data-gallery={variantGallery.length > 0 ? JSON.stringify(variantGallery) : JSON.stringify(allImages)}
                                            >
                                                {v.nom_court || v.Nom_du_produit}
                                            </button>
                                        );
                                    })}
                                </div>
                            </div>
                        )}

                        <hr class="divider" />

                        <!-- CTA -->
                        <div class="cta-group">
                            {produit.Bouton_acheter ? (
                                <a href={produit.Bouton_acheter} class="btn btn-buy" target="_blank" rel="noopener noreferrer">
                                     Acheter maintenant
                                </a>
                            ) : (
                                <a href="/contact" class="btn btn-buy"> Demander un devis</a>
                            )}
                            <a href="/boutique" class="btn btn-outline">&larr; Retour boutique</a>
                        </div>
                    </div>
                </section>

                <!-- ===== BAS DE PAGE : Description + FAQ + Avis ===== -->
                <section class="product-bottom">

                    <!-- DESCRIPTION LONGUE -->
                    {produit.description_principale && (
                        <div class="tab-section">
                            <h2 class="section-title">Description complète</h2>
                            <div class="rich-content" set:html={produit.description_principale} />
                        </div>
                    )}

                    <!-- FAQ (placeholder pour plus tard) -->
                    <div class="tab-section faq-section">
                        <h2 class="section-title">Questions fréquentes</h2>
                        <div class="faq-placeholder">
                            <p>🔧 Les questions fréquentes seront disponibles prochainement.</p>
                            <p>Pour toute question, <a href="/contact">contactez-nous &rarr;</a></p>
                        </div>
                    </div>

                    <!-- AVIS (placeholder pour plus tard) -->
                    <div class="tab-section">
                        <h2 class="section-title">Avis clients</h2>
                        <div class="reviews-placeholder">
                            <p class="stars">★★★★★</p>
                            <p>Les avis clients seront affichés ici prochainement.</p>
                        </div>
                    </div>

                    <!-- PRODUITS SIMILAIRES -->
                    {produitsSimilaires.length > 0 && (
                        <div class="similar-products">
                            <h2 class="section-title main-title">Produits <span class="gradient-text">Similaires</span></h2>
                            <div class="similar-grid">
                                {produitsSimilaires.map((p: any) => (
                                    <article class="similar-card">
                                        <a href={`/produits/${p.slug || p.id}`} class="similar-card-img">
                                            {p.image ? (
                                                <img src={`${directusUrl}/assets/${p.image}`} alt={p.Nom_du_produit} />
                                            ) : (
                                                <div class="similar-placeholder">🦾</div>
                                            )}
                                        </a>
                                        <div class="similar-card-body">
                                            {p.marque && <div class="brand-tag">{p.marque}</div>}
                                            <h3><a href={`/produits/${p.slug || p.id}`}>{p.Nom_du_produit}</a></h3>
                                            <p class="similar-price">{p.prix ? `${p.prix} €` : 'Contact'}</p>
                                            <a href={`/produits/${p.slug || p.id}`} class="similar-btn">Voir &rarr;</a>
                                        </div>
                                    </article>
                                ))}
                            </div>
                        </div>
                    )}

                </section>
            </>
        )}
    </div>
</Layout>

<style>
    .page-wrapper {
        padding-top: 2rem;
        padding-bottom: 5rem;
    }

    /* BREADCRUMB */
    .breadcrumb {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.82rem; color: var(--text-light);
        margin-bottom: 2rem; flex-wrap: wrap;
    }
    .breadcrumb a { color: #818cf8; text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: #a5b4fc; }
    .sep { color: #4a5568; }

    /* ===== BLOC PRINCIPAL ===== */
    .product-top {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: flex-start;
        margin-bottom: 3rem;
    }

    /* GALERIE / CARROUSEL */
    .product-gallery { position: sticky; top: 6rem; }
    
    .carousel-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .carousel-main {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--surface);
    }
    .carousel-main img {
        width: 100%;
        aspect-ratio: 1 / 1;
        /* object-fit: cover assure que les images de tailles différentes remplissent parfaitement le carré sans être déformées */
        object-fit: cover;
        display: block;
        transition: opacity 0.3s ease-in-out;
    }
    
    /* Boutons de contrôle (flèches) */
    .carousel-controls {
        position: absolute;
        top: 50%;
        left: 0; right: 0;
        transform: translateY(-50%);
        display: flex;
        justify-content: space-between;
        padding: 0 1rem;
        pointer-events: none; /* Laisse cliquer au travers sauf sur les boutons */
    }
    .carousel-controls button {
        pointer-events: auto;
        background: rgba(15, 23, 42, 0.7);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        width: 40px; height: 40px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        backdrop-filter: blur(4px);
        transition: background 0.2s, transform 0.2s;
    }
    .carousel-controls button:hover {
        background: var(--primary, #6366f1);
        transform: scale(1.1);
    }

    /* Vignettes (thumbnails) */
    .carousel-thumbnails {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
    }
    .carousel-thumbnails::-webkit-scrollbar {
        height: 6px;
    }
    .carousel-thumbnails::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 6px;
    }
    .thumbnail-btn {
        flex: 0 0 80px;
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        background: var(--surface);
        padding: 0;
        opacity: 0.6;
        transition: opacity 0.2s, border-color 0.2s;
    }
    .thumbnail-btn:hover {
        opacity: 0.9;
    }
    .thumbnail-btn.active {
        opacity: 1;
        border-color: #6366f1;
    }
    .thumbnail-btn img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Pareil ici, les vignettes gardent une bonne proportion */
        display: block;
    }
    .image-placeholder {
        border-radius: 20px;
        border: 1px dashed var(--border);
        background: var(--surface);
        aspect-ratio: 1 / 1;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 1rem; color: var(--text-light);
    }
    .image-placeholder span { font-size: 4rem; }

    /* INFOS DROITE */
    .product-details {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    .product-tag {
        font-size: 0.72rem; font-weight: 600;
        color: #818cf8; text-transform: uppercase; letter-spacing: 1.5px;
    }
    h1 {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        font-weight: 900; color: #fff;
        line-height: 1.2; letter-spacing: -0.5px;
    }
    .price-block {
        display: flex; align-items: baseline; gap: 1rem;
        flex-wrap: wrap;
    }
    .price {
        font-size: 2.4rem; font-weight: 900;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .original-price {
        font-size: 1.5rem;
        text-decoration: line-through;
        color: #a0aec0;
        background: none;
        -webkit-background-clip: unset; -webkit-text-fill-color: unset; background-clip: unset;
    }
    .promo-price {
        color: #ef4444;
        background: none;
        -webkit-background-clip: unset; -webkit-text-fill-color: unset; background-clip: unset;
    }
    .price-note {
        font-size: 0.82rem; color: var(--text-light);
    }
    .short-desc {
        font-size: 1rem; color: var(--text-light);
        line-height: 1.7;
    }
    .divider {
        border: none; border-top: 1px solid var(--border); margin: 0;
    }
    .cta-group {
        display: flex; flex-direction: column; gap: 0.75rem;
    }
    .btn-buy {
        font-size: 1.05rem;
        padding: 0.9rem 2rem;
        border-radius: 12px;
        text-align: center;
    }

    /* VARIANTES */
    .variants-selection { margin-top: 1rem; }
    .variants-label { font-size: 0.88rem; font-weight: 600; color: #fff; margin-bottom: 0.75rem; display: block; }
    .variants-grid { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .variant-btn {
        background: var(--surface);
        border: 1px solid var(--border);
        color: #fff;
        padding: 0.6rem 1.25rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .variant-btn:hover { border-color: #818cf8; background: rgba(99, 102, 241, 0.05); }
    .variant-btn.active {
        border-color: #6366f1;
        background: rgba(99, 102, 241, 0.1);
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.2);
    }

    /* GARANTIES */
    .trust-badges {
        display: flex; gap: 0.75rem; flex-wrap: wrap;
        margin-top: 0.25rem;
    }
    .badge {
        display: flex; align-items: center; gap: 0.4rem;
        font-size: 0.8rem; color: var(--text-light);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px; padding: 0.4rem 0.75rem;
    }
    .badge span { font-size: 1rem; }

    /* ===== BAS DE PAGE ===== */
    .product-bottom {
        border-top: 1px solid var(--border);
        padding-top: 3rem;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }
    .tab-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem 2.5rem;
    }
    .section-title {
        font-size: 1.35rem; font-weight: 800; color: #fff;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

    /* WYSIWYG — :global() requis car set:html échappe au scope Astro */
    :global(.rich-content) { color: var(--text); line-height: 1.85; font-size: 1rem; }
    :global(.rich-content h2) { font-size: 1.3rem; font-weight: 800; color: #fff; margin: 1.75rem 0 0.6rem; }
    :global(.rich-content h3) { font-size: 1.1rem; font-weight: 700; color: #e2e8f0; margin: 1.25rem 0 0.5rem; }
    :global(.rich-content h4) { font-size: 1rem; font-weight: 600; color: #cbd5e1; margin: 1rem 0 0.4rem; }
    :global(.rich-content p) { margin-bottom: 1.1rem; }
    :global(.rich-content br) { display: block; margin-bottom: 0.5rem; }
    :global(.rich-content ul) { list-style: disc; margin: 0.75rem 0 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
    :global(.rich-content ol) { list-style: decimal; margin: 0.75rem 0 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
    :global(.rich-content li::marker) { color: #6366f1; }
    :global(.rich-content strong) { color: #e2e8f0; font-weight: 700; }
    :global(.rich-content em) { font-style: italic; color: #a5b4fc; }
    :global(.rich-content a) { color: #818cf8; text-decoration: underline; text-underline-offset: 3px; }
    :global(.rich-content a:hover) { color: #a5b4fc; }
    :global(.rich-content blockquote) {
        border-left: 3px solid #6366f1;
        padding: 0.75rem 1.25rem; margin: 1.25rem 0;
        background: rgba(99,102,241,0.08); border-radius: 0 8px 8px 0;
        color: #a5b4fc; font-style: italic;
    }
    :global(.rich-content img) { max-width: 100%; border-radius: 10px; margin: 1.25rem 0; display: block; }
    :global(.rich-content hr) { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
    :global(.rich-content table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    :global(.rich-content th) { background: rgba(99,102,241,0.1); color: #a5b4fc; padding: 0.75rem 1rem; text-align: left; font-weight: 600; border: 1px solid var(--border); }
    :global(.rich-content td) { padding: 0.65rem 1rem; border: 1px solid var(--border); color: var(--text); }

    /* FAQ PLACEHOLDER */
    .faq-placeholder, .reviews-placeholder {
        text-align: center;
        padding: 2rem;
        color: var(--text-light);
        font-size: 0.95rem;
        line-height: 1.7;
    }
    .faq-placeholder a { color: #818cf8; text-decoration: underline; }
    .stars { font-size: 2rem; color: #f59e0b; margin-bottom: 0.5rem; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .product-top { grid-template-columns: 1fr; gap: 2rem; }
        .product-gallery { position: static; }
        .tab-section { padding: 1.5rem; }
    }

    .error-box {
        background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5; padding: 2rem; border-radius: 12px; text-align: center;
    }

    /* PRODUITS SIMILAIRES */
    .similar-products {
        margin-top: 2rem;
    }
    .similar-products .main-title {
        border-bottom: none;
        margin-bottom: 2rem;
        text-align: center;
        font-size: 2rem;
    }
    .gradient-text {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .similar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
    }
    .similar-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        transition: transform 0.2s, border-color 0.2s;
    }
    .similar-card:hover {
        transform: translateY(-5px);
        border-color: #6366f1;
    }
    .similar-card-img {
        display: block;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: var(--surface-2);
        padding: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: padding 0.4s ease;
    }
    .similar-card-img img {
        width: 100%; height: 100%;
        object-fit: contain;
        border-radius: 20px;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .similar-card:hover .similar-card-img { 
        padding: 0; 
    }
    .similar-card:hover .similar-card-img img { 
        transform: scale(1.05); 
    }
    .similar-placeholder {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.5rem; background: rgba(99,102,241,0.05);
    }
    .similar-card-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .brand-tag {
        font-size: 0.68rem; font-weight: 700; color: #818cf8; text-transform: uppercase; letter-spacing: 1px;
    }
    .similar-card-body h3 { font-size: 1.05rem; font-weight: 700; margin: 0; }
    .similar-card-body h3 a { color: #fff; text-decoration: none; }
    .similar-card-body h3 a:hover { color: #818cf8; }
    .similar-price { font-size: 1.1rem; font-weight: 800; color: #818cf8; margin: 0; }
    .similar-btn {
        margin-top: 0.5rem;
        font-size: 0.85rem; font-weight: 600; color: #818cf8;
        text-decoration: none; display: flex; align-items: center; gap: 0.25rem;
    }
    .similar-btn:hover { text-decoration: underline; }

    @media (max-width: 640px) {
        .similar-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
    // Script exécuté côté client pour gérer le carrousel
    document.addEventListener('DOMContentLoaded', () => {
        const mainImg = document.getElementById('main-carousel-img') as HTMLImageElement;
        const thumbnails = document.querySelectorAll('.thumbnail-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');

        if (!mainImg || thumbnails.length === 0) return;

        let currentIndex = 0;

        function updateCarousel(index: number) {
            // On récupère les miniatures actuelles (peuvent avoir changé avec une variante)
            const currentThumbnails = document.querySelectorAll('.thumbnail-btn');
            if (currentThumbnails.length === 0) return;

            const newImage = currentThumbnails[index].getAttribute('data-image');
            if (newImage && mainImg) {
                // Petit effet de fondu transparent
                mainImg.style.opacity = '0.5';
                setTimeout(() => {
                    mainImg.src = newImage;
                    mainImg.style.opacity = '1';
                }, 150);
            }
            
            // Mettre à jour la classe active sur les vignettes
            currentThumbnails.forEach(t => t.classList.remove('active'));
            currentThumbnails[index].classList.add('active');
            
            // Scroller la vignette pour qu'elle soit visible
            (currentThumbnails[index] as HTMLElement).scrollIntoView({
                behavior: 'smooth',
                block: 'nearest',
                inline: 'center'
            });
        }

        // Fonction pour attacher les écouteurs aux vignettes
        function attachThumbnailEvents() {
            const currentThumbnails = document.querySelectorAll('.thumbnail-btn');
            currentThumbnails.forEach((thumb, index) => {
                // On clone pour éviter les doubles écouteurs si nécessaire
                const newThumb = thumb.cloneNode(true);
                thumb.parentNode?.replaceChild(newThumb, thumb);
                newThumb.addEventListener('click', () => {
                    currentIndex = index;
                    updateCarousel(currentIndex);
                });
            });
        }

        // Initialisation
        attachThumbnailEvents();

        // Flèches de navigation
        if (prevBtn && nextBtn) {
            prevBtn.addEventListener('click', () => {
                currentIndex = (currentIndex > 0) ? currentIndex - 1 : thumbnails.length - 1;
                updateCarousel(currentIndex);
            });

            nextBtn.addEventListener('click', () => {
                currentIndex = (currentIndex < thumbnails.length - 1) ? currentIndex + 1 : 0;
                updateCarousel(currentIndex);
            });
        }

        // --- GESTION DES VARIANTES ---
        const variantBtns = document.querySelectorAll('.variant-btn');
        const priceBlock = document.getElementById('price-block-container');
        const buyBtn = document.querySelector('.btn-buy') as HTMLAnchorElement;
        const shortDesc = document.querySelector('.short-desc');
        const longDesc = document.querySelector('.rich-content');
        const carouselThumbnails = document.querySelector('.carousel-thumbnails');

        variantBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Mettre à jour l'état actif
                variantBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                // Récupérer les données des attributs
                const newPrice = btn.getAttribute('data-price');
                const isPromo = btn.getAttribute('data-promo') === 'true';
                const newPrixPromo = btn.getAttribute('data-prix-promo');
                const newImage = btn.getAttribute('data-image');
                const newUrl = btn.getAttribute('data-url');
                const newDescShort = btn.getAttribute('data-desc-short');
                const newDescLong = btn.getAttribute('data-desc-long');
                const newGalleryStr = btn.getAttribute('data-gallery');

                // Mise à jour du Prix
                if (priceBlock && newPrice) {
                    if (isPromo && newPrixPromo) {
                        const cleanPromo = newPrixPromo.replace(',', '.').replace(/[^\d.-]/g, '');
                        const promoVal = parseFloat(cleanPromo);
                        let finalPromoStr = newPrixPromo;
                        if (!isNaN(promoVal)) {
                            finalPromoStr = promoVal.toFixed(2).replace('.00', '') + (newPrixPromo.includes('€') ? '' : ' €');
                        } else if (!finalPromoStr.includes('€')) {
                            finalPromoStr += ' €';
                        }
                        
                        priceBlock.innerHTML = `
                            <span class="price original-price">${newPrice.includes('€') ? newPrice : newPrice + ' €'}</span>
                            <span class="price promo-price">${finalPromoStr}</span>
                            <span class="price-note">TTC · Livraison incluse</span>
                        `;
                    } else {
                        // Cas sans promo
                        priceBlock.innerHTML = `
                            <span class="price">${newPrice.includes('€') ? newPrice : newPrice + ' €'}</span>
                            <span class="price-note">TTC · Livraison incluse</span>
                        `;
                    }
                }

                // Mise à jour de l'image (si on en a une)
                if (newImage && mainImg) {
                    mainImg.style.opacity = '0.5';
                    setTimeout(() => {
                        mainImg.src = newImage;
                        mainImg.style.opacity = '1';
                    }, 150);
                }

                // Mise à jour du lien d'achat
                if (buyBtn && newUrl) {
                    buyBtn.href = newUrl;
                }

                // Mise à jour des descriptions
                if (shortDesc && newDescShort) {
                    shortDesc.textContent = newDescShort;
                }
                if (longDesc && newDescLong) {
                    longDesc.innerHTML = newDescLong;
                }

                // Mise à jour de la Galerie (Vignettes)
                if (carouselThumbnails && newGalleryStr) {
                    try {
                        const gallery = JSON.parse(newGalleryStr);
                        if (Array.isArray(gallery) && gallery.length > 0) {
                            // On récupère le nom du produit pour l'alt
                            const productName = document.querySelector('h1')?.textContent || 'Produit';
                            
                            // On vide et on reconstruit les vignettes avec des dimensions forcées (80x80)
                            carouselThumbnails.innerHTML = gallery.map((imgUrl, index) => `
                                <button 
                                    class="thumbnail-btn ${index === 0 ? 'active' : ''}" 
                                    data-index="${index}"
                                    data-image="${imgUrl}"
                                    aria-label="Voir l'image ${index + 1}"
                                    style="flex: 0 0 80px; width: 80px; height: 80px; padding: 0; overflow: hidden; border-radius: 12px;"
                                >
                                    <img src="${imgUrl}" alt="${productName} - vue ${index + 1}" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                                </button>
                            `).join('');

                            // Ré-attacher les écouteurs de clics aux nouvelles vignettes via la fonction partagée
                            attachThumbnailEvents();
                            
                            // Reset l'index à 0 pour la nouvelle galerie
                            currentIndex = 0;
                        }
                    } catch (e) { console.error("Erreur parsing galerie:", e); }
                }
            });
        });
    });
</script>
