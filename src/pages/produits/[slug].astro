</style>

<script>
    // Script exécuté côté client pour gérer le carrousel
    document.addEventListener('DOMContentLoaded', () => {
        const mainImg = document.getElementById('main-carousel-img') as HTMLImageElement;
        const thumbnails = document.querySelectorAll('.thumbnail-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');

        if (!mainImg || thumbnails.length === 0) return;

        let currentIndex = 0;

        function updateCarousel(index: number) {
            // On récupère les miniatures actuelles (peuvent avoir changé avec une variante)
            const currentThumbnails = document.querySelectorAll('.thumbnail-btn');
            if (currentThumbnails.length === 0) return;

            const newImage = currentThumbnails[index].getAttribute('data-image');
            if (newImage && mainImg) {
                // Petit effet de fondu transparent
                mainImg.style.opacity = '0.5';
                setTimeout(() => {
                    mainImg.src = newImage;
                    mainImg.style.opacity = '1';
                }, 150);
            }
            
            // Mettre à jour la classe active sur les vignettes
            currentThumbnails.forEach(t => t.classList.remove('active'));
            currentThumbnails[index].classList.add('active');
            
            // Scroller la vignette pour qu'elle soit visible
            (currentThumbnails[index] as HTMLElement).scrollIntoView({
                behavior: 'smooth',
                block: 'nearest',
                inline: 'center'
            });
        }

        // Fonction pour attacher les écouteurs aux vignettes
        function attachThumbnailEvents() {
            const currentThumbnails = document.querySelectorAll('.thumbnail-btn');
            currentThumbnails.forEach((thumb, index) => {
                // On clone pour éviter les doubles écouteurs si nécessaire
                const newThumb = thumb.cloneNode(true);
                thumb.parentNode?.replaceChild(newThumb, thumb);
                newThumb.addEventListener('click', () => {
                    currentIndex = index;
                    updateCarousel(currentIndex);
                });
            });
        }

        // Initialisation
        attachThumbnailEvents();

        // Flèches de navigation
        if (prevBtn && nextBtn) {
            prevBtn.addEventListener('click', () => {
                currentIndex = (currentIndex > 0) ? currentIndex - 1 : thumbnails.length - 1;
                updateCarousel(currentIndex);
            });

            nextBtn.addEventListener('click', () => {
                currentIndex = (currentIndex < thumbnails.length - 1) ? currentIndex + 1 : 0;
                updateCarousel(currentIndex);
            });
        }

        // --- GESTION DES VARIANTES ---
        const variantBtns = document.querySelectorAll('.variant-btn');
        const priceBlock = document.getElementById('price-block-container');
        const buyBtn = document.querySelector('.btn-buy') as HTMLAnchorElement;
        const shortDesc = document.querySelector('.short-desc');
        const longDesc = document.querySelector('.rich-content');
        const carouselThumbnails = document.querySelector('.carousel-thumbnails');

        variantBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Mettre à jour l'état actif
                variantBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                // Récupérer les données des attributs
                const newPrice = btn.getAttribute('data-price');
                const isPromo = btn.getAttribute('data-promo') === 'true';
                const newPrixPromo = btn.getAttribute('data-prix-promo');
                const newImage = btn.getAttribute('data-image');
                const newUrl = btn.getAttribute('data-url');
                const newDescShort = btn.getAttribute('data-desc-short');
                const newDescLong = btn.getAttribute('data-desc-long');
                const newGalleryStr = btn.getAttribute('data-gallery');

                // Mise à jour du Prix
                if (priceBlock && newPrice) {
                    if (isPromo && newPrixPromo) {
                        const cleanPromo = newPrixPromo.replace(',', '.').replace(/[^\d.-]/g, '');
                        const promoVal = parseFloat(cleanPromo);
                        let finalPromoStr = newPrixPromo;
                        if (!isNaN(promoVal)) {
                            finalPromoStr = promoVal.toFixed(2).replace('.00', '') + (newPrixPromo.includes('€') ? '' : ' €');
                        } else if (!finalPromoStr.includes('€')) {
                            finalPromoStr += ' €';
                        }
                        
                        priceBlock.innerHTML = `
                            <span class="price original-price">${newPrice.includes('€') ? newPrice : newPrice + ' €'}</span>
                            <span class="price promo-price">${finalPromoStr}</span>
                        `;
                    } else {
                        // Cas sans promo
                        priceBlock.innerHTML = `
                            <span class="price">${newPrice.includes('€') ? newPrice : newPrice + ' €'}</span>
                        `;
                    }
                }

                // Mise à jour de l'image (si on en a une)
                if (newImage && mainImg) {
                    mainImg.style.opacity = '0.5';
                    setTimeout(() => {
                        mainImg.src = newImage;
                        mainImg.style.opacity = '1';
                    }, 150);
                }

                // Mise à jour du lien d'achat
                if (buyBtn && newUrl) {
                    buyBtn.href = newUrl;
                }

                // Mise à jour des descriptions
                if (shortDesc && newDescShort) {
                    shortDesc.textContent = newDescShort;
                }
                if (longDesc && newDescLong) {
                    longDesc.innerHTML = newDescLong;
                }

                // Mise à jour de la Galerie (Vignettes)
                if (carouselThumbnails && newGalleryStr) {
                    try {
                        const gallery = JSON.parse(newGalleryStr);
                        if (Array.isArray(gallery) && gallery.length > 0) {
                            // On récupère le nom du produit pour l'alt
                            const productName = document.querySelector('h1')?.textContent || 'Produit';
                            
                            // On vide et on reconstruit les vignettes avec des dimensions forcées (80x80)
                            carouselThumbnails.innerHTML = gallery.map((imgUrl, index) => `
                                <button 
                                    class="thumbnail-btn ${index === 0 ? 'active' : ''}" 
                                    data-index="${index}"
                                    data-image="${imgUrl}"
                                    aria-label="Voir l'image ${index + 1}"
                                    style="flex: 0 0 80px; width: 80px; height: 80px; padding: 0; overflow: hidden; border-radius: 12px;"
                                >
                                    <img src="${imgUrl}" alt="${productName} - vue ${index + 1}" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                                </button>
                            `).join('');

                            // Ré-attacher les écouteurs de clics aux nouvelles vignettes via la fonction partagée
                            attachThumbnailEvents();
                            
                            // Reset l'index à 0 pour la nouvelle galerie
                            currentIndex = 0;
                        }
                    } catch (e) { console.error("Erreur parsing galerie:", e); }
                }
            });
        });

        // ===== GESTION DU FORMULAIRE D'AVIS =====
        const avisForm = document.getElementById('avis-form') as HTMLFormElement | null;
        if (avisForm) {
            const starBtns = avisForm.querySelectorAll('.star-btn');
            const noteInput = document.getElementById('note-value') as HTMLInputElement | null;
            const prenomInput = document.getElementById('avis-prenom') as HTMLInputElement | null;
            const emailInput = document.getElementById('avis-email') as HTMLInputElement | null;
            const avisTexteInput = document.getElementById('avis-texte') as HTMLTextAreaElement | null;
            const submitBtn = document.getElementById('avis-submit') as HTMLButtonElement | null;
            const successMsg = document.getElementById('avis-success');
            const errorGlobal = document.getElementById('avis-error-global');

            let selectedNote = 0;

            // Gestion des étoiles cliquables
            starBtns.forEach((btn) => {
                const val = parseInt(btn.getAttribute('data-value') || '0');

                btn.addEventListener('mouseenter', () => {
                    starBtns.forEach((b) => {
                        const bVal = parseInt(b.getAttribute('data-value') || '0');
                        b.classList.toggle('hover-preview', bVal <= val);
                    });
                });

                btn.addEventListener('mouseleave', () => {
                    starBtns.forEach((b) => {
                        b.classList.remove('hover-preview');
                        const bVal = parseInt(b.getAttribute('data-value') || '0');
                        b.classList.toggle('active', bVal <= selectedNote);
                    });
                });

                btn.addEventListener('click', () => {
                    selectedNote = val;
                    if (noteInput) noteInput.value = String(selectedNote);
                    starBtns.forEach((b) => {
                        const bVal = parseInt(b.getAttribute('data-value') || '0');
                        b.classList.toggle('active', bVal <= selectedNote);
                    });
                    const noteError = document.getElementById('note-error');
                    if (noteError) noteError.textContent = '';
                });
            });

            // Validation d'un champ
            function validateField(input: HTMLInputElement | HTMLTextAreaElement, errorId: string, rules: { required?: boolean; email?: boolean }): boolean {
                const errorEl = document.getElementById(errorId);
                const val = input.value.trim();
                input.classList.remove('error', 'valid');

                if (rules.required && !val) {
                    input.classList.add('error');
                    if (errorEl) errorEl.textContent = 'Ce champ est obligatoire.';
                    return false;
                }
                if (rules.email && val) {
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    if (!emailRegex.test(val)) {
                        input.classList.add('error');
                        if (errorEl) errorEl.textContent = 'Veuillez entrer une adresse email valide.';
                        return false;
                    }
                }
                input.classList.add('valid');
                if (errorEl) errorEl.textContent = '';
                return true;
            }

            // Validation en temps réel au départ du champ
            prenomInput?.addEventListener('blur', () => prenomInput && validateField(prenomInput, 'prenom-error', { required: true }));
            emailInput?.addEventListener('blur', () => emailInput && validateField(emailInput, 'email-error', { required: true, email: true }));
            avisTexteInput?.addEventListener('blur', () => avisTexteInput && validateField(avisTexteInput, 'avis-texte-error', { required: true }));

            // Soumission du formulaire
            avisForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                // Validation complète avant envoi
                let valid = true;
                if (selectedNote === 0) {
                    const noteError = document.getElementById('note-error');
                    if (noteError) noteError.textContent = 'Veuillez sélectionner une note.';
                    valid = false;
                }
                if (prenomInput && !validateField(prenomInput, 'prenom-error', { required: true })) valid = false;
                if (emailInput && !validateField(emailInput, 'email-error', { required: true, email: true })) valid = false;
                if (avisTexteInput && !validateField(avisTexteInput, 'avis-texte-error', { required: true })) valid = false;

                if (!valid) return;

                // Désactiver le bouton pendant l'envoi
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Envoi en cours...';
                }
                if (successMsg) successMsg.style.display = 'none';
                if (errorGlobal) errorGlobal.style.display = 'none';

                // Construction du payload
                const formData = new FormData(avisForm);
                const payload: Record<string, any> = {};
                formData.forEach((value, key) => {
                    if (key === 'note') {
                        payload[key] = parseInt(value as string);
                    } else if ((value as string).trim() !== '') {
                        payload[key] = value;
                    }
                });

                try {
                    const response = await fetch('/api/avis', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.message || `Erreur ${response.status}`);
                    }

                    // Succès : reset du formulaire
                    avisForm.reset();
                    selectedNote = 0;
                    starBtns.forEach((b) => b.classList.remove('active', 'hover-preview'));
                    if (noteInput) noteInput.value = '';
                    prenomInput?.classList.remove('valid');
                    emailInput?.classList.remove('valid');
                    avisTexteInput?.classList.remove('valid');
                    if (successMsg) {
                        successMsg.style.display = 'block';
                        // Rechargement automatique après 2 secondes pour afficher le nouvel avis
                        setTimeout(() => {
                            window.location.reload();
                        }, 2000);
                    }

                } catch (err: any) {
                    console.error('Erreur envoi avis:', err);
                    if (errorGlobal) {
                        errorGlobal.textContent = `⚠️ Une erreur est survenue (${err.message}). Veuillez vérifier les permissions de la collection Avis dans Directus.`;
                        errorGlobal.style.display = 'block';
                    }
                } finally {
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Envoyer mon avis';
                    }
                }
            });
        }
    });
</script>
