---
// page : /produits/[slug]
// Layout e-commerce standard : image gauche / infos droite + description + FAQ + avis
import Layout from '../../layouts/Layout.astro';
import { fetchDirectus } from '../../lib/directus';

const { slug } = Astro.params;
const directusUrl = "https://spirited-squid.pikapod.net";

let produit: any = null;
let produitsSimilaires: any[] = [];
let avis: any[] = [];
let errorMessage: string | null = null;

try {
    // On ajoute galerie.* pour récupérer les relations Directus
    const data = await fetchDirectus(
        `/items/Produits?filter[slug][_eq]=${slug}&fields=id,Nom_du_produit,nom_court,prix,descripton_simple,description_principale,Bouton_acheter,image,slug,galerie.*,marque,variantes.*,variantes.galerie.*,promo,prix_promo,faqs.*,seo_description,custom_alts&limit=1`
    );
    produit = Array.isArray(data) ? data[0] : data;

    // Récupération des produits similaires (priorité à la même marque si elle existe)
    if (produit) {
        // Tentative de récupération des produits de la même marque (excluant le produit actuel)
        const brandFilter = produit.marque ? `&filter[marque][_eq]=${produit.marque}` : '';
        const others = await fetchDirectus(
            `/items/Produits?filter[slug][_neq]=${slug}${brandFilter}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=4`
        );
        produitsSimilaires = Array.isArray(others) ? others : [];

        if (produitsSimilaires.length < 4) {
            const excludeSlugs = [slug, ...produitsSimilaires.map(p => p.slug || p.id)];
            const fallbackQuery = `/items/Produits?filter[slug][_nin]=${excludeSlugs.join(',')}&fields=id,Nom_du_produit,prix,descripton_simple,slug,image,marque&limit=${4 - produitsSimilaires.length}`;
            const more = await fetchDirectus(fallbackQuery);
            if (Array.isArray(more)) {
                produitsSimilaires = [...produitsSimilaires, ...more];
            }
        }

        // Récupération des avis pour ce produit
        try {
            const avisData = await fetchDirectus(
                `/items/Avis?filter[produit_slug][_eq]=${slug}&fields=prenom,note,avis_texte&limit=50`
            );
            avis = Array.isArray(avisData) ? avisData : [];
        } catch (e: any) {
            console.error(`[Avis Debug] Erreur sur ${slug}:`, e.message);
            avis = [];
        }
    }
} catch (error: any) {
    console.error(`Erreur produit ${slug}:`, error);
    errorMessage = error.message;
}

// Calcul de la note moyenne
const noteMoyenne = avis.length > 0
    ? Math.round((avis.reduce((sum: number, a: any) => sum + (a.note || 0), 0) / avis.length) * 10) / 10
    : null;

if (!produit && !errorMessage) {
    return Astro.redirect('/404');
}

// Extraction de l'image principale
const imageUrl = produit?.image
    ? `${directusUrl}/assets/${produit.image}`
    : null;

// Extraction des images de la galerie
let allImages: string[] = [];
if (imageUrl) allImages.push(imageUrl);

if (produit?.galerie && Array.isArray(produit.galerie)) {
    produit.galerie.forEach((item: any) => {
        // La clé dépend de votre config sur Directus. M2M par défaut c'est directus_files_id
        const fileId = item.directus_files_id || item.image || (typeof item === 'string' ? item : null);
        if (fileId) {
            allImages.push(`${directusUrl}/assets/${fileId}`);
        }
    });
}
let isPromoValid = false;
let displayPromoPrice = '';

if (produit && produit.promo && produit.prix_promo) {
    const rawPromo = String(produit.prix_promo).replace(',', '.').replace(/[^\d.-]/g, '');
    const promoNum = parseFloat(rawPromo);
    
    if (!isNaN(promoNum)) {
        isPromoValid = true;
        displayPromoPrice = `${promoNum.toFixed(2).replace('.00', '')} €`;
    } else {
        isPromoValid = true;
        displayPromoPrice = String(produit.prix_promo).includes('€') ? produit.prix_promo : `${produit.prix_promo} €`;
    }
}

const productJsonLd = produit ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": produit.Nom_du_produit,
    "description": produit.seo_description || produit.descripton_simple || '',
    "image": allImages.slice(0, 3),
    "brand": produit.marque ? {
        "@type": "Brand",
        "name": produit.marque
    } : undefined,
    "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "price": isPromoValid 
            ? produit.prix_promo.replace(/[^\d.,]/g, '').replace(',', '.') 
            : (produit.prix ? produit.prix.replace(/[^\d.,]/g, '').replace(',', '.') : "0"),
        "availability": "https://schema.org/InStock",
        "url": Astro.url.href
    }
}) : null;

const faqJsonLd = (produit?.faqs && produit.faqs.length > 0) ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": produit.faqs.map((f: any) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.reponse.replace(/<[^>]*>?/gm, '') // Strip HTML for JSON-LD text
    }
  }))
}) : null;

const metaDescription = produit?.seo_description || produit?.descripton_simple || 'Exosquelette NeoSomaTech';

const customAlts = produit?.custom_alts 
    ? produit.custom_alts.split('\n').map((line: string) => line.trim()).filter((line: string) => line.length > 0)
    : [];



---

<Layout
    title={produit ? `${produit.Nom_du_produit} | NeoSomaTech` : 'Produit introuvable'}
    description={metaDescription}
    image={imageUrl || '/favicon.png'}
>
    {productJsonLd && <script type="application/ld+json" set:html={productJsonLd} />}
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}


    <div class="page-wrapper container">

        {errorMessage ? (
            <div class="error-box">⚠️ {errorMessage}</div>
        ) : produit && (
            <>
                <!-- BREADCRUMB -->
                <nav class="breadcrumb">
                    <a href="/">Accueil</a>
                    <span class="sep">/</span>
                    <a href="/boutique">Boutique</a>
                    <span class="sep">/</span>
                    <span>{produit.Nom_du_produit}</span>
                </nav>

                <!-- ===== BLOC PRINCIPAL (image gauche / infos droite) ===== -->
                <style is:inline>
                    /* CSS CRITIQUE : Fixe la mise en page AVANT le chargement du CSS Astro */
                    .product-top { 
                        display: grid !important; 
                        grid-template-columns: 1fr 1fr !important; 
                        gap: 3rem !important; 
                        opacity: 0; 
                    }
                    .carousel-main { aspect-ratio: 1/1 !important; width: 100% !important; max-width: 600px !important; background: #1a1a2e; border-radius: 20px; }
                    .product-top.is-ready { opacity: 1; transition: opacity 0.2s ease-in; }
                    @media (max-width: 768px) { .product-top { grid-template-columns: 1fr !important; } }
                </style>

                <section class="product-top" id="main-product-section">
                    <script is:inline>
                        // On affiche le contenu dès que la structure est là
                        (function(){
                            const el = document.getElementById('main-product-section');
                            if(el) el.classList.add('is-ready');
                        })();
                    </script>
                    <!-- IMAGE GAUCHE (CARROUSEL) -->
                    <div class="product-gallery">
                        {allImages.length > 0 ? (
                            <div class="carousel-container">
                                <div class="carousel-main">
                                    <img 
                                        id="main-carousel-img" 
                                        src={allImages[0]} 
                                        alt={customAlts[0] || produit.Nom_du_produit} 
                                        width="800" 
                                        height="800" 
                                        style="aspect-ratio: 1/1; width: 100%; height: auto; object-fit: cover;"
                                        fetchpriority="high"
                                        loading="eager"
                                    />
                                    
                                    {allImages.length > 1 && (
                                        <div class="carousel-controls">
                                            <button id="prev-btn" aria-label="Image précédente">&larr;</button>
                                            <button id="next-btn" aria-label="Image suivante">&rarr;</button>
                                        </div>
                                    )}
                                </div>
                                {allImages.length > 1 && (
                                    <div class="carousel-thumbnails">
                                        {allImages.map((imgUrl, index) => (
                                            <button 
                                                class={`thumbnail-btn ${index === 0 ? 'active' : ''}`} 
                                                data-index={index}
                                                data-image={imgUrl}
                                                aria-label={`Voir l'image ${index + 1}`}
                                            >
                                                <img 
                                                    src={imgUrl} 
                                                    alt={customAlts[index] || `${produit.Nom_du_produit} - vue ${index + 1}`} 
                                                    width="80" 
                                                    height="80" 
                                                    style="aspect-ratio: 1/1; object-fit: cover;"
                                                    loading="lazy"
                                                />
                                            </button>
                                        ))}
                                    </div>
                                )}
                            </div>
                        ) : (
                            <div class="image-placeholder">
                                <span>🦾</span>
                                <p>Image à venir</p>
                            </div>
                        )}
                    </div>

                    <!-- INFOS DROITE -->
                    <div class="product-details">
                        <div class="product-tag">Exosquelette</div>
                        <h1>{produit.Nom_du_produit}</h1>

                        <!-- PRIX -->
                        <div class="price-block" id="price-block-container">
                            {isPromoValid ? (
                                <>
                                    <span class="price original-price">
                                        {produit.prix ? `${produit.prix} €` : ''}
                                    </span>
                                    <span class="price promo-price">
                                        {displayPromoPrice}
                                    </span>
                                </>
                            ) : (
                                <span class="price">
                                    {produit.prix ? `${produit.prix} €` : 'Nous contacter'}
                                </span>
                            )}
                        </div>

                        <!-- DESCRIPTION COURTE -->
                        {produit.descripton_simple && (
                            <p class="short-desc">{produit.descripton_simple}</p>
                        )}

                        <!-- VARIANTES -->
                        {produit.variantes && produit.variantes.length > 0 && (
                            <div class="variants-selection">
                                <span class="variants-label">Choisir un modèle :</span>
                                <div class="variants-grid">
                                    <button 
                                        class="variant-btn active" 
                                        data-name="Standard"
                                        data-price={produit.prix || ''}
                                        data-promo={isPromoValid ? 'true' : 'false'}
                                        data-prix-promo={produit.prix_promo || ''}
                                        data-image={imageUrl}
                                        data-url={produit.Bouton_acheter || ''}
                                        data-desc-short={produit.descripton_simple || ''}
                                        data-desc-long={produit.description_principale || ''}
                                        data-gallery={JSON.stringify(allImages)}
                                    >
                                        {produit.nom_court || 'Par défaut'}
                                    </button>
                                    {produit.variantes.map((v: any) => {
                                        // Collecte des images de la galerie de la variante
                                        let variantGallery: string[] = [];
                                        if (v.Image) variantGallery.push(`${directusUrl}/assets/${v.Image}`);
                                        if (v.galerie && Array.isArray(v.galerie)) {
                                            v.galerie.forEach((item: any) => {
                                                const fileId = item.directus_files_id || item.image || (typeof item === 'string' ? item : null);
                                                if (fileId) variantGallery.push(`${directusUrl}/assets/${fileId}`);
                                            });
                                        }

                                        return (
                                            <button 
                                                class="variant-btn" 
                                                data-name={v.nom_court || v.Nom_du_produit}
                                                data-price={v.prix || produit.prix || ''}
                                                data-promo={v.promo ? 'true' : 'false'}
                                                data-prix-promo={v.prix_promo || ''}
                                                data-image={v.Image ? `${directusUrl}/assets/${v.Image}` : imageUrl}
                                                data-url={v.bouton_acheter || v.Lien_achat || produit.Bouton_acheter || ''}
                                                data-desc-short={v.description_simple || produit.descripton_simple || ''}
                                                data-desc-long={v.description_principale || produit.description_principale || ''}
                                                data-gallery={variantGallery.length > 0 ? JSON.stringify(variantGallery) : JSON.stringify(allImages)}
                                            >
                                                {v.nom_court || v.Nom_du_produit}
                                            </button>
                                        );
                                    })}
                                </div>
                            </div>
                        )}

                        <hr class="divider" />

                        <!-- CTA -->
                        <div class="cta-group">
                            {produit.Bouton_acheter ? (
                                <a href={produit.Bouton_acheter} class="btn btn-buy" target="_blank" rel="noopener noreferrer">
                                     Acheter maintenant
                                </a>
                            ) : (
                                <a href="/contact" class="btn btn-buy"> Demander un devis</a>
                            )}
                            <a href="/boutique" class="btn btn-outline">&larr; Retour boutique</a>
                        </div>
                    </div>
                </section>

                <!-- ===== BAS DE PAGE : Description + FAQ + Avis ===== -->
                <section class="product-bottom">

                    <!-- DESCRIPTION LONGUE -->
                    {produit.description_principale && (
                        <div class="tab-section">
                            <h2 class="section-title">Description complète</h2>
                            <div class="rich-content" set:html={produit.description_principale} />
                        </div>
                    )}

                    <!-- FAQ -->
                    <div class="tab-section faq-section">
                        <h2 class="section-title">Questions fréquentes</h2>
                        {produit.faqs && produit.faqs.length > 0 ? (
                            <div class="faq-accordion">
                                {produit.faqs.map((f: any) => (
                                    <details class="faq-item">
                                        <summary class="faq-question">
                                            <span>{f.question}</span>
                                            <span class="faq-icon"></span>
                                        </summary>
                                        <div class="faq-answer">
                                            <div class="rich-content" set:html={f.reponse} />
                                        </div>
                                    </details>
                                ))}
                            </div>
                        ) : (
                            <div class="faq-placeholder">
                                <p>🔧 Les questions fréquentes seront disponibles prochainement.</p>
                                <p>Pour toute question, <a href="/contact">contactez-nous &rarr;</a></p>
                            </div>
                        )}
                    </div>

                    <!-- AVIS CLIENTS -->
                    <div class="tab-section" id="avis-section">
                        <div class="avis-header">
                            <h2 class="section-title" style="margin-bottom:0; border-bottom:none;">Avis clients</h2>
                            {noteMoyenne && (
                                <div class="avis-moyenne">
                                    <span class="avis-moyenne-note">{noteMoyenne}</span>
                                    <div class="avis-moyenne-etoiles">
                                        {[1,2,3,4,5].map(i => (
                                            <span class={i <= Math.round(noteMoyenne) ? 'star filled' : 'star'}>★</span>
                                        ))}
                                    </div>
                                    <span class="avis-count">({avis.length} avis)</span>
                                </div>
                            )}
                        </div>
                        <div style="border-bottom: 1px solid var(--border); margin: 1.25rem 0;"></div>

                        <!-- Liste des avis existants -->
                        {avis.length > 0 ? (
                            <div class="avis-liste">
                                {avis.map((a: any) => (
                                    <div class="avis-card">
                                        <div class="avis-card-top">
                                            <div class="avis-avatar">{a.prenom ? a.prenom[0].toUpperCase() : '?'}</div>
                                            <div class="avis-meta">
                                                <strong class="avis-prenom">{a.prenom || 'Anonyme'}</strong>
                                                <div class="avis-etoiles">
                                                    {[1,2,3,4,5].map(i => (
                                                        <span class={i <= (a.note || 0) ? 'star filled' : 'star'}>★</span>
                                                    ))}
                                                </div>
                                            </div>
                                            {a.date_created && (
                                                <span class="avis-date">
                                                    {new Date(a.date_created).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                                                </span>
                                            )}
                                        </div>
                                        <p class="avis-commentaire">{a.avis_texte}</p>
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <p class="avis-empty">Soyez le premier à donner votre avis sur ce produit !</p>
                        )}

                        <!-- Formulaire de soumission -->
                        <div class="avis-form-container">
                            <h3 class="avis-form-title">Laisser un avis</h3>
                            <form id="avis-form" novalidate>
                                <input type="hidden" name="produit_slug" value={slug} />

                                <!-- Note avec étoiles -->
                                <div class="form-group">
                                    <label class="form-label">Note <span class="required">*</span></label>
                                    <div class="stars-input" id="stars-input" role="group" aria-label="Note de 1 à 5">
                                        {[1,2,3,4,5].map(i => (
                                            <button type="button" class="star-btn" data-value={i} aria-label={`${i} étoile${i > 1 ? 's' : ''}`}>★</button>
                                        ))}
                                    </div>
                                    <input type="hidden" name="note" id="note-value" value="" />
                                    <span class="field-error" id="note-error"></span>
                                </div>

                                <div class="form-row">
                                    <!-- Prénom -->
                                    <div class="form-group">
                                        <label for="avis-prenom" class="form-label">Prénom <span class="required">*</span></label>
                                        <input type="text" id="avis-prenom" name="prenom" class="form-input" placeholder="Votre prénom" autocomplete="given-name" />
                                        <span class="field-error" id="prenom-error"></span>
                                    </div>
                                    <!-- Email -->
                                    <div class="form-group">
                                        <label for="avis-email" class="form-label">Email <span class="required">*</span></label>
                                        <input type="email" id="avis-email" name="email" class="form-input" placeholder="votre@email.com" autocomplete="email" />
                                        <span class="field-error" id="email-error"></span>
                                    </div>
                                </div>

                                <!-- Téléphone -->
                                <div class="form-group">
                                    <label for="avis-tel" class="form-label">Téléphone <span class="optional">(facultatif)</span></label>
                                    <input type="tel" id="avis-tel" name="telephone" class="form-input" placeholder="+33 6 12 34 56 78" autocomplete="tel" />
                                </div>

                                <!-- Commentaire -->
                                <div class="form-group">
                                    <label for="avis-texte" class="form-label">Commentaire <span class="required">*</span></label>
                                    <textarea id="avis-texte" name="avis_texte" class="form-input form-textarea" placeholder="Partagez votre expérience avec ce produit..." rows={4}></textarea>
                                    <span class="field-error" id="avis-texte-error"></span>
                                </div>

                                <div class="form-footer">
                                    <span class="form-note"><span class="required">*</span> Champs obligatoires</span>
                                    <button type="submit" class="btn btn-buy" id="avis-submit">Envoyer mon avis</button>
                                </div>

                                <div id="avis-success" class="avis-success" style="display:none;">
                                    ✅ Merci ! Votre avis a bien été enregistré.
                                </div>
                                <div id="avis-error-global" class="avis-error-global" style="display:none;">
                                    ⚠️ Une erreur est survenue. Veuillez réessayer.
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- PRODUITS SIMILAIRES -->
                    {produitsSimilaires.length > 0 && (
                        <div class="similar-products">
                            <h2 class="section-title main-title">Produits <span class="gradient-text">Similaires</span></h2>
                            <div class="similar-grid">
                                {produitsSimilaires.map((p: any) => (
                                    <article class="similar-card">
                                        <a href={`/produits/${p.slug || p.id}`} class="similar-card-img">
                                            {p.image ? (
                                                <img src={`${directusUrl}/assets/${p.image}`} alt={p.Nom_du_produit} />
                                            ) : (
                                                <div class="similar-placeholder">🦾</div>
                                            )}
                                        </a>
                                        <div class="similar-card-body">
                                            {p.marque && <div class="brand-tag">{p.marque}</div>}
                                            <h3><a href={`/produits/${p.slug || p.id}`}>{p.Nom_du_produit}</a></h3>
                                            <p class="similar-price">{p.prix ? `${p.prix} €` : 'Contact'}</p>
                                            <a href={`/produits/${p.slug || p.id}`} class="similar-btn">Voir &rarr;</a>
                                        </div>
                                    </article>
                                ))}
                            </div>
                        </div>
                    )}

                </section>
            </>
        )}
    </div>
</Layout>

<style>
    .page-wrapper {
        padding-top: 2rem;
        padding-bottom: 5rem;
    }

    /* BREADCRUMB */
    .breadcrumb {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.82rem; color: var(--text-light);
        margin-bottom: 2rem; flex-wrap: wrap;
    }
    .breadcrumb a { color: #818cf8; text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: #a5b4fc; }
    .sep { color: #4a5568; }

    /* ===== BLOC PRINCIPAL ===== */
    .product-top {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: flex-start;
        margin-bottom: 3rem;
    }

    /* GALERIE / CARROUSEL */
    .product-gallery { position: sticky; top: 6rem; }
    
    .carousel-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .carousel-main {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--surface);
    }
    .carousel-main img {
        width: 100%;
        aspect-ratio: 1 / 1;
        /* object-fit: cover assure que les images de tailles différentes remplissent parfaitement le carré sans être déformées */
        object-fit: cover;
        display: block;
        transition: opacity 0.3s ease-in-out;
    }
    
    /* Boutons de contrôle (flèches) */
    .carousel-controls {
        position: absolute;
        top: 50%;
        left: 0; right: 0;
        transform: translateY(-50%);
        display: flex;
        justify-content: space-between;
        padding: 0 1rem;
        pointer-events: none; /* Laisse cliquer au travers sauf sur les boutons */
    }
    .carousel-controls button {
        pointer-events: auto;
        background: rgba(15, 23, 42, 0.7);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        width: 40px; height: 40px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        backdrop-filter: blur(4px);
        transition: background 0.2s, transform 0.2s;
    }
    .carousel-controls button:hover {
        background: var(--primary, #6366f1);
        transform: scale(1.1);
    }

    /* Vignettes (thumbnails) */
    .carousel-thumbnails {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
    }
    .carousel-thumbnails::-webkit-scrollbar {
        height: 6px;
    }
    .carousel-thumbnails::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 6px;
    }
    .thumbnail-btn {
        flex: 0 0 80px;
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        background: var(--surface);
        padding: 0;
        opacity: 0.6;
        transition: opacity 0.2s, border-color 0.2s;
    }
    .thumbnail-btn:hover {
        opacity: 0.9;
    }
    .thumbnail-btn.active {
        opacity: 1;
        border-color: #6366f1;
    }
