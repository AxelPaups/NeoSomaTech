---
import Layout from '../../layouts/Layout.astro';
import { directus } from '../../lib/directus';
import { readItem } from '@directus/sdk';

const { id } = Astro.params;

let produit = null;
try {
    produit = await directus.request(
        readItem('Produits', id, {
            fields: ['id', 'Nom_du_produit', 'prix', 'descripton_simple', 'description_principale', 'Bouton_acheter']
        })
    );
} catch (error) {
    console.error(`Erreur Directus lors de la récupération du produit ${id}:`, error);
    // Si on ne trouve pas le produit, Astro renverra une erreur 404 (si on le gère)
    return Astro.redirect('/404');
}

if (!produit) {
    return Astro.redirect('/404');
}
---

<Layout title={`${produit.Nom_du_produit} - NeoSomaTech`}>
    <div class="product-page">
        <div class="back-link">
            <a href="/">&larr; Retour à l'accueil</a>
        </div>

        <article class="product-detail">
            <div class="product-header">
                <h1>{produit.Nom_du_produit}</h1>
                <div class="price-tag">{produit.prix ? `${produit.prix} €` : 'Prix sur demande'}</div>
            </div>

            <div class="product-content">
                <div class="summary">
                    <h2>En bref</h2>
                    <p>{produit.descripton_simple}</p>
                </div>
                
                {produit.description_principale && (
                    <div class="main-description">
                        <h2>Description Détaillée</h2>
                        <div class="html-content" set:html={produit.description_principale} />
                    </div>
                )}
            </div>

            <div class="product-actions">
                {produit.Bouton_acheter ? (
                    <a href={produit.Bouton_acheter} class="btn btn-large" target="_blank" rel="noopener noreferrer">Acheter Maintenant</a>
                ) : (
                    <button class="btn btn-large" onclick="alert('Lien d\'achat non disponible.')">Acheter Maintenant</button>
                )}
            </div>
        </article>
    </div>
</Layout>

<style>
    .product-page {
        max-width: 800px;
        margin: 0 auto;
    }
    .back-link {
        margin-bottom: 2rem;
    }
    .back-link a {
        color: var(--text-light);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }
    .back-link a:hover {
        color: var(--primary);
    }
    .product-detail {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 3rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: 1px solid var(--border);
    }
    .product-header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 2rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .product-header h1 {
        font-size: 2.5rem;
        color: var(--text);
        margin: 0;
        letter-spacing: -1px;
        font-weight: 800;
    }
    .price-tag {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
        background: #eef2ff;
        padding: 0.5rem 1rem;
        border-radius: 8px;
    }
    .summary {
        font-size: 1.25rem;
        color: var(--text-light);
        line-height: 1.6;
        margin-bottom: 3rem;
    }
    .summary h2, .main-description h2 {
        font-size: 1.5rem;
        color: var(--text);
        margin-bottom: 1rem;
    }
    .main-description {
        margin-bottom: 3rem;
    }
    .html-content {
        line-height: 1.8;
        color: var(--text);
    }
    .html-content p {
        margin-bottom: 1rem;
    }
    .product-actions {
        text-align: center;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }
    .btn-large {
        font-size: 1.25rem;
        padding: 1rem 3rem;
    }

    @media (max-width: 600px) {
        .product-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
